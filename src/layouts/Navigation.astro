---
import Button from "../components/Button.astro";

const navItems = [
	{ href: "/kenyan-buyers", label: "Buy from us", hasMenu: true },
	{ href: "/sell-with-us", label: "Sell with us" },
	{ href: "/our-impact", label: "Our Impact" },
	{ href: "/our-story", label: "About us", hasMenu: true },
];
---

<nav
	class="mx-auto flex max-w-7xl items-center justify-between gap-6 rounded-full bg-yellow-50 px-5 py-4 shadow-sm ring-1 ring-brown-100/70 md:px-8"
	aria-label="Primary navigation">
	<a
		href="/"
		class="flex shrink-0 items-center gap-2 text-green-500"
		aria-label="Farm to Feed home">
		<span class="flex h-7 w-3 flex-col gap-1">
			<span class="h-2 w-3 rounded-full bg-orange-500"></span>
			<span class="h-2 w-3 rounded-full bg-green-500"></span>
			<span class="h-2 w-3 rounded-full bg-green-500"></span>
		</span>
		<span class="leading-none">
			<span class="block text-[11px] font-semibold tracking-[-0.02em]">farm</span>
			<span class="block text-[11px] font-semibold tracking-[-0.02em]">to feed</span>
		</span>
	</a>

	<div class="hidden items-center gap-1 text-sm text-black lg:flex">
		{
			navItems.map((item) => (
				<a
					href={item.href}
					class="inline-flex items-center gap-1 rounded-full px-4 py-2 leading-6 transition-colors duration-150 hover:bg-white/75 hover:text-green-500">
					{item.label}
					{item.hasMenu && <span class="pi pi-chevron-down text-[10px]"></span>}
				</a>
			))
		}
	</div>

	<Button
		isLink
		href="/contact-us"
		variant="secondary"
		size="xs"
		class="h-10 px-5 text-sm font-normal leading-6 tracking-[0.03em] text-neutral-50">
		Log In
	</Button>
</nav>
