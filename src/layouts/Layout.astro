---
import Header from "./Header.astro";
import Navigation from "./Navigation.astro";
import Footer from "./Footer.astro";
import "primeicons/primeicons.css";
import "../styles/tailwind.css";
const { title = "FTF Website", description = "FTF Website" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<Header title={title} description={description} />

	<body>
		<div
			class="min-h-screen grid grid-rows-[auto_1fr_auto] bg-slate-50 text-slate-900">
			<header
				class="site-header bg-white border-b border-slate-200 px-6 py-5">
				<div class="brand">
					<a href="/" class="text-slate-950 font-bold text-lg">FTF</a>
				</div>
				<Navigation />
			</header>

			<main class="site-main mx-auto w-full max-w-5xl px-6 py-10">
				<slot />
			</main>

			<Footer />
		</div>
	</body>
</html>
