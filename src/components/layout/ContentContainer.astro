---
const {
  as = "div",
  size = "default",
  class: className = "",
  ...rest
} = Astro.props;

const Tag = as;
const sizes = {
  narrow: "max-w-[960px]",
  default: "max-w-[1184px]",
  wide: "max-w-7xl",
};
const sizeClass = sizes[size as keyof typeof sizes] ?? sizes.default;
---

<Tag
  class:list={[
    "relative z-10 mx-auto w-full px-5 sm:px-8 lg:px-10",
    sizeClass,
    className,
  ]}
  {...rest}
>
  <slot />
</Tag>
