---
import type { ImageMetadata } from "astro";
import type { HTMLAttributes } from "astro/types";
import { Image } from "astro:assets";

interface Props extends HTMLAttributes<"img"> {
	src: ImageMetadata | string;
	widths?: number[];
	sizes?: string;
	format?: "avif" | "png" | "webp" | "jpg" | "jpeg" | "svg";
	quality?: number | string;
}

const {
	src,
	widths,
	sizes,
	format = "webp",
	quality = 82,
	loading = "lazy",
	decoding = "async",
	...attrs
} = Astro.props;

const isLocalImage = typeof src !== "string";
---

{
	isLocalImage ? (
		<Image
			src={src}
			widths={widths}
			sizes={sizes}
			format={format}
			quality={quality}
			loading={loading}
			decoding={decoding}
			{...attrs}
		/>
	) : (
		<img
			src={src}
			loading={loading}
			decoding={decoding}
			{...attrs}
		/>
	)
}
