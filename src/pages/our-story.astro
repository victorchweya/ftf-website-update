												hidden={
													index !== activeStoryIndex
												}
												style="--transform-inner-width: 1185; --transform-inner-height: 21;">
												{" "}
												<div class="flex-none rotate-[12.37deg]">
													{" "}
													<div
														class="h-[107.586px] relative w-[29.19px]"
														data-name="Capa_1">
														{" "}
														<Fragment
															set:html={
																OurStorySvgs.OurStorySvg45
															}
														/>{" "}
													</div>{" "}
												</div>{" "}
											</div>{" "}
										</button>
									))
								}
							</div>
							<input
								aria-label="Story timeline"
								class="pointer-events-none absolute inset-x-[9%] top-0 z-10 h-[65px] cursor-pointer opacity-0"
								max={storySlides.length - 1}
								min="0"
								step="1"
								type="range"
