</Layout>
<script>
	const timelines = document.querySelectorAll("[data-story-timeline]");
	timelines.forEach((timeline) => {
		const slides = JSON.parse(timeline.getAttribute("data-slides") || "[]");
		const buttons = Array.from(
			timeline.querySelectorAll("[data-story-index]"),
		);
		const field = timeline.querySelector("[data-slider-field]");
		const milestones = timeline.querySelector("[data-milestones]");
		const range = timeline.querySelector("[data-story-range]");
		const body = timeline.querySelector("[data-story-body]");
		let activeIndex = 0;
		let isDragging = false;
		function setActive(index) {
			activeIndex = Math.max(0, Math.min(slides.length - 1, index));
			buttons.forEach((button, buttonIndex) => {
				const marker = button.querySelector("[data-active-marker]");
				if (buttonIndex === activeIndex) {
					button.setAttribute("aria-current", "step");
					marker?.removeAttribute("hidden");
				} else {
					button.removeAttribute("aria-current");
					marker?.setAttribute("hidden", "");
				}
			});
			if (range instanceof HTMLInputElement) {
				range.value = String(activeIndex);
			}
			if (body) {
				body.textContent = slides[activeIndex]?.body || "";
			}
		}
		function updateFromPointer(clientX) {
			if (!(milestones instanceof HTMLElement) || !slides.length) {
				return;
			}
			const rect = milestones.getBoundingClientRect();
			const progress = Math.min(
				Math.max((clientX - rect.left) / rect.width, 0),
				1,
			);
			setActive(Math.round(progress * (slides.length - 1)));
		}
		buttons.forEach((button) => {
			button.addEventListener("click", () => {
				setActive(Number(button.getAttribute("data-story-index")) || 0);
			});
		});
		field?.addEventListener("pointerdown", (event) => {
			isDragging = true;
			field.setPointerCapture?.(event.pointerId);
			updateFromPointer(event.clientX);
		});
		field?.addEventListener("pointermove", (event) => {
			if (isDragging) {
				updateFromPointer(event.clientX);
			}
		});
		function stopDrag(event) {
			isDragging = false;
			field?.releasePointerCapture?.(event.pointerId);
		}
		field?.addEventListener("pointerup", stopDrag);
		field?.addEventListener("pointercancel", stopDrag);
		setActive(activeIndex);
	});
</script>
