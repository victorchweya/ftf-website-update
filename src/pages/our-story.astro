	},
	{
		class: "col-1 h-[6.815px] ml-[78.88px] mt-[70.83px] relative row-1 w-[3.58px]",
		svg: OurStorySvgs.OurStorySvg31,
	},
	{
		class: "col-1 h-[3.509px] ml-[83.02px] mt-[71.44px] relative row-1 w-[5.417px]",
		svg: OurStorySvgs.OurStorySvg32,
	},
	{
		class: "col-1 h-[0.007px] ml-[91.97px] mt-[75.21px] relative row-1 w-0",
		svg: OurStorySvgs.OurStorySvg33,
	},
	{
		class: "col-1 h-[54.75px] ml-[6.18px] mt-[19.8px] relative row-1 w-[40.737px]",
		svg: OurStorySvgs.OurStorySvg35,
	},
	{
		class: "col-1 h-[4.319px] ml-[21.02px] mt-[28.01px] relative row-1 w-[7.269px]",
		svg: OurStorySvgs.OurStorySvg36,
	},
	{
		class: "col-1 h-[2.896px] ml-[14.18px] mt-[32.24px] relative row-1 w-[3.279px]",
		svg: OurStorySvgs.OurStorySvg37,
	},
	{
		class: "col-1 h-[3.763px] ml-[9.26px] mt-[35.73px] relative row-1 w-[5.239px]",
		svg: OurStorySvgs.OurStorySvg38,
	},
	{
		class: "col-1 h-[32.622px] ml-[16.14px] mt-[36.21px] relative row-1 w-[19.745px]",
		svg: OurStorySvgs.OurStorySvg39,
	},
	{
		class: "col-1 h-[30.573px] ml-[26.73px] mt-[29.99px] relative row-1 w-[17.151px]",
		svg: OurStorySvgs.OurStorySvg40,
	},
	{
		class: "col-1 h-[14.102px] ml-[47.29px] mt-[47.29px] relative row-1 w-[6.979px]",
		svg: OurStorySvgs.OurStorySvg42,
	},
	{
		class: "col-1 h-[43.183px] ml-[6.1px] mt-[42.37px] relative row-1 w-[100.296px]",
		svg: OurStorySvgs.OurStorySvg43,
	},
];

const activeStoryIndex = 0;
---

<Layout title="Our Story">
	<div
		class="bg-white flex flex-col items-start relative w-full"
		data-name="Our Story">
		<section class="relative shrink-0 w-full" data-name="Wireframe - 53">
			<ContentContainer size="wide" class="h-full">
				<div
					class="relative grid w-full min-h-[540px] max-w-[913px] mt-20 mx-auto items-center gap-8 md:grid-cols-[minmax(0,570px)_279px] md:gap-16">
					<p class={`${typeStyles.heroTitleLarge} text-green-800`}>
						Farm to Feed began with a simple but urgent idea
					</p>
					<p class={`${typeStyles.bodyLarge} text-green-500`}>
						Tackling food loss in Kenya's fresh produce supply
						chain. We introduced grade rescue to the Nairobi market,
						creating a pathway for vegetables that might otherwise
						go to waste.
					</p>
				</div>
			</ContentContainer>

			<div class="relative" data-name="our-story-divider">
				<img
					alt=""
					aria-hidden="true"
					class="w-full h-full object-cover"
					src={ourStoryDividerUrl}
				/>
				<div
					class="absolute hidden h-[198px] right-50 top-0 w-[203.25px] md:block"
					data-name="Group">
					<Fragment set:html={OurStorySvgs.OurStorySvg46} />
				</div>
			</div>
		</section>

		<section
			class="bg-white overflow-clip relative shrink-0 w-full"
			data-name="Wireframe - 10">
			<ContentContainer size="wide" class="h-full">
				<div
					class="relative flex h-full flex-col items-center min-h-[540px] max-w-[760px] mt-20 mx-auto gap-8 md:gap-16">
					<p
						class={`${typeStyles.sectionTitle} not-italic text-[#0f251b] text-center w-full max-w-148`}>
						Connecting production to dependable demand...
					</p>
					<div
						class={`${typeStyles.body} mt-[24px] md:mt-[55px] leading-zero not-italic text-[#0f251b] text-center w-full max-w-148 whitespace-pre-wrap`}>
						<p class="leading-copy mb-0">
							As we worked alongside our customers and farmers, we
							quickly learned that food loss is one part of a much
							larger challenge. Farmers needed more than a
							solution for imperfect produce. They needed reliable
							market access for their full harvest.
						</p>
						<p class="leading-copy">
							Since those early days, Farm to Feed has grown into
							a trusted off taker and partner for farmers, helping
							to address one of Kenya's most persistent
							agricultural bottlenecks: connecting production to
							dependable demand.
						</p>
					</div>
					<div
						class="flex flex-col gap-12 mb-24 items-center md:flex-row md:gap-16 md:mb-40">
						{
							storyPrinciples.map((principle) => (
								<div class="grid-cols-[max-content] grid-rows-[max-content] inline-grid place-items-start relative shrink-0">
									<div
										class="col-1 h-[336px] ml-0 relative row-1 w-75.75"
										data-name="Vector"
										style={`margin-top: ${principle.cardTop};`}>
										<div class="absolute inset-[-1.19%_-7.92%_-13.1%_-7.92%]">
											<Fragment
												set:html={
													OurStorySvgs.OurStorySvg47
												}
											/>
										</div>
									</div>
									<div class="col-1 flex flex-col gap-12 items-center ml-11.5 mt-0 relative row-1 w-54.25">
										{principle.icon === "vision" ? (
											<div class="grid-cols-[max-content] grid-rows-[max-content] inline-grid leading-zero place-items-start relative shrink-0">
												<div
													class="col-1 h-[124px] ml-0 mt-0 relative row-1 w-[127.288px]"
													data-name="Group">
													<Fragment
														set:html={
															OurStorySvgs.OurStorySvg01
														}
													/>
												</div>
												<div
													class="col-1 h-[64.416px] ml-[39.9px] mt-[29.59px] relative row-1 w-[57.169px]"
													data-name="Isolation_Mode">
													<Fragment
														set:html={
															OurStorySvgs.OurStorySvg02
														}
													/>
												</div>
											</div>
										) : (
											<div class="grid-cols-[max-content] grid-rows-[max-content] inline-grid leading-zero place-items-start relative shrink-0">
												<div class="col-1 flex h-[124px] items-center justify-center ml-0 mt-0 relative row-1 w-[127.221px]">
													<div class="-scale-y-100 flex-none rotate-180">
														<div
															class="h-[124px] relative w-[127.221px]"
															data-name="Vector">
															<Fragment
																set:html={
																	OurStorySvgs.OurStorySvg03
																}
															/>
														</div>
													</div>
												</div>
												<div
													class="col-1 h-[51.532px] ml-[26.17px] mt-[41.87px] overflow-clip relative row-1 w-[74.883px]"
													data-name="Isolation_Mode">
													<div
														class="absolute inset-[-0.01%_-0.02%_-0.02%_0]"
														data-name="Vector">
														<Fragment
															set:html={
																OurStorySvgs.OurStorySvg04
															}
														/>
													</div>
												</div>
											</div>
										)}
										<div class="flex flex-col gap-6 items-center not-italic relative shrink-0 text-center w-full">
											<p
												class={`${typeStyles.body} relative shrink-0 text-[#85a687] whitespace-nowrap`}>
												{principle.label}
											</p>
											<p
												class={`${typeStyles.cardTitle} relative shrink-0 text-[#0f251b] w-full`}>
												{principle.body}
											</p>
										</div>
									</div>
								</div>
							))
						}
					</div>
				</div>
			</ContentContainer>
			<div
				class="-translate-x-1/2 -translate-y-1/2 absolute hidden h-[601px] left-[33.5px] top-[calc(20%+266px)] w-[441px] lg:block"
				data-name="Vector">
				<img
					alt=""
					class="absolute block inset-0 max-w-none size-full"
					height="601"
					src={storyIllustrationOneUrl}
					width="441"
				/>
			</div>
			<div
				class="-translate-x-1/2 -translate-y-1/2 absolute hidden h-[601px] items-center justify-center left-[calc(100%-46.5px)] top-[calc(20%+369px)] w-[441px] lg:flex">
				<div class="-scale-y-100 flex-none rotate-180">
					<div
						class="h-[601px] relative w-[441px]"
						data-name="Vector">
						<img
							alt=""
							class="absolute block inset-0 max-w-none size-full"
							height="601"
							src={storyIllustrationTwoUrl}
							width="441"
						/>
					</div>
				</div>
			</div>
		</section>

		<section
			class="bg-white min-h-[500px] md:min-h-[580px] overflow-clip relative shrink-0 w-full mb-24"
			data-name="Wireframe - 54">
			<ContentContainer size="wide">
				<div
					class="relative flex flex-col items-center gap-16 md:gap-[124px]">
					<div
						class="absolute hidden md:flex h-[87px] items-center justify-center left-1/2 -translate-x-1/2 top-58 w-[485px]"
						style="container-type:size">
						<div class="flex-none h-[100cqw] rotate-90 w-[100cqh]">
							<div class="relative size-full" data-name="Vector">
								<Fragment
									set:html={OurStorySvgs.OurStorySvg48}
								/>
							</div>
						</div>
					</div>
					<div
						class="flex flex-col items-center relative w-full max-w-[758px]">
						<p
							class={`${typeStyles.sectionTitle} not-italic relative shrink-0 text-[#030806] text-center w-full`}>
							Farm to Feed is the tech-enabled platform
						</p>
					</div>
					<div
						class="flex flex-col md:flex-row gap-12 md:gap-8 items-center md:items-start relative w-full max-w-[952px]">
						{
							platformSteps.map((step) => (
								<div
									class={`flex flex-col items-center relative w-full md:flex-[1_0_0] md:min-w-px ${step.title ? "gap-8 md:gap-14" : "pt-[25px]"}`}>
									{step.illustration === "farmers" ? (
										<div class="h-[198.445px] relative shrink-0 w-[203.707px]">
											<Fragment
												set:html={
													OurStorySvgs.OurStorySvg05
												}
											/>
										</div>
									) : step.illustration === "platform" ? (
										<div class="h-[198.445px] relative shrink-0 w-[203.707px]">
											<Fragment
												set:html={
													OurStorySvgs.OurStorySvg06
												}
											/>
										</div>
									) : (
										<div class="grid-cols-[max-content] grid-rows-[max-content] inline-grid leading-zero place-items-start relative shrink-0">
											<div
												class="col-1 h-[198.445px] ml-0 mt-0 relative row-1 w-[203.707px]"
												data-name="Vector">
												<Fragment
													set:html={
														OurStorySvgs.OurStorySvg07
													}
												/>
											</div>
											<div
												class="col-1 h-[37.983px] ml-[93px] mt-[21px] relative row-1 w-[27px]"
												data-name="Vector">
												<Fragment
													set:html={
														OurStorySvgs.OurStorySvg08
													}
												/>
											</div>
											<div
												class="col-1 grid-cols-[max-content] grid-rows-[max-content] inline-grid ml-[46.64px] mt-[63.7px] place-items-start relative row-1"
												data-name="Group">
												{customerIllustrationSvgs.map(
													(item) => (
														<div
															class={item.class}
															data-name="Vector">
															<Fragment
																set:html={
																	item.svg
																}
															/>
														</div>
													),
												)}
												<div class="col-1 flex h-[57.474px] items-center justify-center ml-[70.36px] mt-[24.07px] relative row-1 w-[30.966px]">
													<div class="-scale-y-100 flex-none rotate-180">
														<div class="h-[57.474px] relative w-[30.966px]">
															<Fragment
																set:html={
																	OurStorySvgs.OurStorySvg34
																}
															/>
														</div>
													</div>
												</div>
												<div
													class="col-1 flex h-[60.714px] items-center justify-center ml-[46.36px] mt-[12.3px] relative row-1 w-[41.077px]"
													style="--transform-inner-width: 1185; --transform-inner-height: 21;">
													<div class="flex-none rotate-[-11.76deg]">
														<div class="h-[55.694px] relative w-[30.361px]">
															<Fragment
																set:html={
																	OurStorySvgs.OurStorySvg41
																}
															/>
														</div>
													</div>
												</div>
												<div
													class="col-1 flex h-[26.716px] items-center justify-center ml-0 mt-[66.85px] relative row-1 w-[113.379px]"
													style="--transform-inner-width: 1185; --transform-inner-height: 21;">
													<div class="-scale-y-100 flex-none rotate-[177.8deg]">
														<div
															class="h-[22.402px] relative w-[112.601px]"
															data-name="Vector">
															<Fragment
																set:html={
																	OurStorySvgs.OurStorySvg44
																}
															/>
														</div>
													</div>
												</div>
											</div>
										</div>
									)}
									{step.title && step.body && (
										<div class="flex flex-col gap-6 items-start not-italic relative shrink-0 text-black text-center w-full">
											<p
												class={`${typeStyles.cardTitle} relative shrink-0 w-full`}>
												{step.title}
											</p>
											<p
												class={`${typeStyles.body} relative shrink-0 w-full`}>
												{step.body}
											</p>
										</div>
									)}
								</div>
							))
						}
					</div>
				</div>
			</ContentContainer>
		</section>

		<section
			class="min-h-[600px] md:min-h-[750px] overflow-clip relative shrink-0 w-full"
			data-name="Story"
			data-story-timeline
			data-slides={JSON.stringify(storySlides)}>
			<ContentContainer size="wide" class="relative z-10 pb-64">
				<div class="relative flex flex-col items-center gap-16">
					<p
						class={`${typeStyles.heroTitleLarge} text-green-800 text-center w-full max-w-[544px]`}>
						Our story
					</p>
					<p
						class={`${typeStyles.body} not-italic text-black text-center`}>
						Slide the carrot across the timeline or tap to learn
						about our journey
					</p>
					<div
						class="relative flex flex-col items-center gap-20 w-full"
						data-name="slider">
						<div
							class="relative h-[65px] w-full max-w-[607px]"
							data-name="slider-field"
							data-slider-field
							style="touch-action: none;">
							<div
								class="absolute h-[32px] left-0 right-0 top-[3px]"
								data-name="slider-base">
								<Fragment
									set:html={OurStorySvgs.OurStorySvg52}
								/>
							</div>
							<div
								class="-translate-x-1/2 absolute z-20 flex isolate items-start justify-between left-[calc(50%-4px)] top-0 w-[82%] max-w-[499px]"
								data-name="milestones"
								data-milestones>
								{
									storySlides.map((milestone, index) => (
										<button
											aria-current={
												index === activeStoryIndex
													? "step"
													: undefined
											}
											aria-label={`Show ${milestone.label} story`}
											class="cursor-pointer flex flex-col gap-[5px] items-center relative shrink-0 rounded-[8px] bg-transparent p-0 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#747c50]"
											data-name="milestone"
											data-story-index={index}
											style={`width: ${milestone.width}px; z-index: ${milestone.zIndex};`}
											type="button">
											<div class="bg-[#4c352b] h-[36px] relative rounded-[8px] shrink-0 w-[3px]" />
											<p
												class={`${typeStyles.caption} font-normal not-italic relative shrink-0 text-black whitespace-nowrap`}>
												{milestone.label}
											</p>
											<div
												aria-hidden="true"
												class="absolute flex h-[111.341px] items-center justify-center left-[-12.98px] top-[-31.63px] w-[51.555px]"
												data-active-marker
												hidden={
													index !== activeStoryIndex
												}
												style="--transform-inner-width: 1185; --transform-inner-height: 21;">
												<div class="flex-none rotate-[12.37deg]">
													<div
														class="h-[107.586px] relative w-[29.19px]"
														data-name="Capa_1">
														<Fragment
															set:html={
																OurStorySvgs.OurStorySvg45
															}
														/>
													</div>
												</div>
											</div>
										</button>
									))
								}
							</div>
							<input
								aria-label="Story timeline"
								class="pointer-events-none absolute inset-x-[9%] top-0 z-10 h-[65px] cursor-pointer opacity-0"
								max={storySlides.length - 1}
								min="0"
								step="1"
								type="range"
								value={activeStoryIndex}
								data-story-range
							/>
						</div>
						<div
							class="flex flex-col items-center justify-center mx-auto p-6 md:p-[40px] relative w-full max-w-[560px]"
							data-name="Note">
							<div
								class="absolute flex inset-[0_0.24px_0_0] items-center justify-center"
								style="container-type:size">
								<div
									class="flex-none h-[100cqh] rotate-180 w-[100cqw]">
									<div
										class="relative size-full"
										data-name="Vector">
										<div
											class="absolute inset-[0_-3.66%_-14.08%_-3.66%]">
											<Fragment
												set:html={OurStorySvgs.OurStorySvg53}
											/>
										</div>
									</div>
								</div>
							</div>
							<p
								aria-live="polite"
								class={`${typeStyles.bodyLarge} min-h-[204px] not-italic relative shrink-0 text-black text-center w-full max-w-[467px]`}
								data-story-body>
								{storySlides[activeStoryIndex].body}
							</p>
						</div>
					</div>
				</div>
			</ContentContainer>
			<img
				alt=""
				aria-hidden="true"
				class="pointer-events-none absolute inset-x-0 bottom-[-28px] z-0 w-full select-none"
				src={ourStoryHeroBottomUrl}
			/>
		</section>
	</div>
</Layout>

<script>
	const timelines = document.querySelectorAll("[data-story-timeline]");

	timelines.forEach((timeline) => {
		const slides = JSON.parse(timeline.getAttribute("data-slides") || "[]");
		const buttons = Array.from(
			timeline.querySelectorAll("[data-story-index]"),
		);
		const field = timeline.querySelector("[data-slider-field]");
		const milestones = timeline.querySelector("[data-milestones]");
		const range = timeline.querySelector("[data-story-range]");
		const body = timeline.querySelector("[data-story-body]");
		let activeIndex = 0;
		let isDragging = false;

		function setActive(index) {
			activeIndex = Math.max(0, Math.min(slides.length - 1, index));

			buttons.forEach((button, buttonIndex) => {
				const marker = button.querySelector("[data-active-marker]");
				if (buttonIndex === activeIndex) {
					button.setAttribute("aria-current", "step");
					marker?.removeAttribute("hidden");
				} else {
					button.removeAttribute("aria-current");
					marker?.setAttribute("hidden", "");
				}
			});

			if (range instanceof HTMLInputElement) {
				range.value = String(activeIndex);
			}

			if (body) {
				body.textContent = slides[activeIndex]?.body || "";
			}
		}

		function updateFromPointer(clientX) {
			if (!(milestones instanceof HTMLElement) || !slides.length) {
				return;
			}

			const rect = milestones.getBoundingClientRect();
			const progress = Math.min(
				Math.max((clientX - rect.left) / rect.width, 0),
				1,
			);
			setActive(Math.round(progress * (slides.length - 1)));
		}

		buttons.forEach((button) => {
			button.addEventListener("click", () => {
				setActive(Number(button.getAttribute("data-story-index")) || 0);
			});
		});

		field?.addEventListener("pointerdown", (event) => {
			isDragging = true;
			field.setPointerCapture?.(event.pointerId);
			updateFromPointer(event.clientX);
		});

		field?.addEventListener("pointermove", (event) => {
			if (isDragging) {
				updateFromPointer(event.clientX);
			}
		});

		function stopDrag(event) {
			isDragging = false;
			field?.releasePointerCapture?.(event.pointerId);
		}

		field?.addEventListener("pointerup", stopDrag);
		field?.addEventListener("pointercancel", stopDrag);
		setActive(activeIndex);
	});
</script>
