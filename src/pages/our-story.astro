---
import Layout from "../layouts/Layout.astro";
import ContentContainer from "../components/layout/ContentContainer.astro";
import * as OurStorySvgs from "../lib/figmaMarkup/ourStorySvgs";
import { typeStyles } from "../lib/figmaStyles";
import storyIllustrationOneUrl from "../assets/figma/our-story/story-illustration-1.png?url";
import storyIllustrationTwoUrl from "../assets/figma/our-story/story-illustration-2.png?url";
import ourStoryDividerUrl from "../assets/figma/our-story/divider.png?url";
import ourStoryHeroBottomUrl from "../assets/figma/our-story/hero-bottom.svg?url";

const storySlides = [
	{
		label: "Then",
		body: "In April 2020, Farm to Feed started as a COVID food relief effort. We bought farmers' produce that was at risk of going to waste and donated to food insecure communities who were made more vulnerable at the height of the pandemic.",
		width: 34,
		zIndex: 4,
	},
	{
		label: "2020",
		body: "We catered to ten reliable charities and provided additional income for up to 400 smallholder farmers. We soon realized that the problem of food loss was only exacerbated by the pandemic but existed before and will long outlast it.",
		width: 36,
		zIndex: 3,
	},
	{
		label: "2021",
		body: "A few months later, we developed and piloted our scalable model with the purpose of transforming our food systems for the better.",
		width: 33,
		zIndex: 2,
	},
	{
		label: "Now",
		body: "We now boast a network of thousands of farmers across Kenya and deliver up to 15,000 kgs of fresh food each week. And we're just getting started!",
		width: 30,
		zIndex: 1,
	},
];

const storyPrinciples = [
	{
		body: "Unlock Africa's potential to bring the world high-quality, impactful products",
		cardTop: "86px",
		icon: "vision",
		label: "Vision",
	},
	{
		body: "To build a food system that is sustainable and equitable",
		cardTop: "92.5px",
		icon: "mission",
		label: "Mission",
	},
];

const platformSteps = [
	{
		body: "Aggregating full harvests and producing ingredients that strengthen farmer resilience",
		illustration: "farmers",
		title: "From farmers...",
	},
	{
		illustration: "platform",
	},
	{
		body: "Delivering traceable, sustainable ingredients to buyers through a tech-driven supply chain.",
		illustration: "customers",
		title: "...to B2B customers",
	},
];

const customerIllustrationSvgs = [
	{
		class: "col-1 h-[5.411px] ml-[79.54px] mt-[35.57px] relative row-1 w-[2.257px]",
		svg: OurStorySvgs.OurStorySvg09,
	},
	{
		class: "col-1 h-[5.146px] ml-[99.54px] mt-[41.48px] relative row-1 w-[1.003px]",
		svg: OurStorySvgs.OurStorySvg10,
	},
	{
		class: "col-1 h-[7.402px] ml-[82.33px] mt-[31.93px] relative row-1 w-[2.534px]",
		svg: OurStorySvgs.OurStorySvg11,
	},
	{
		class: "col-1 h-[7.174px] ml-[96.71px] mt-[28.99px] relative row-1 w-[7.819px]",
		svg: OurStorySvgs.OurStorySvg12,
	},
	{
		class: "col-1 h-[43.893px] ml-[79.51px] mt-[36.8px] relative row-1 w-[23.996px]",
		svg: OurStorySvgs.OurStorySvg13,
	},
	{
		class: "col-1 h-[60.621px] ml-[77.69px] mt-[21.93px] relative row-1 w-[28.025px]",
		svg: OurStorySvgs.OurStorySvg14,
	},
	{
		class: "col-1 h-[10.264px] ml-[78.43px] mt-[30.79px] relative row-1 w-[7.732px]",
		svg: OurStorySvgs.OurStorySvg15,
	},
	{
		class: "col-1 h-[10.152px] ml-[93.81px] mt-[38.69px] relative row-1 w-[7.796px]",
		svg: OurStorySvgs.OurStorySvg16,
	},
	{
		class: "col-1 h-[8.116px] ml-[91.19px] mt-[47.35px] relative row-1 w-[8.775px]",
		svg: OurStorySvgs.OurStorySvg17,
	},
	{
		class: "col-1 h-[6.769px] ml-[76.05px] mt-[38.74px] relative row-1 w-[5.299px]",
		svg: OurStorySvgs.OurStorySvg18,
	},
	{
		class: "col-1 h-[6.447px] ml-[74.83px] mt-[43.99px] relative row-1 w-[3.121px]",
		svg: OurStorySvgs.OurStorySvg19,
	},
	{
		class: "col-1 h-[3.454px] ml-[73.46px] mt-[48.21px] relative row-1 w-[1.046px]",
		svg: OurStorySvgs.OurStorySvg20,
	},
	{
		class: "col-1 h-[24.46px] ml-[36.67px] mt-[49.15px] relative row-1 w-[19.718px]",
		svg: OurStorySvgs.OurStorySvg21,
	},
	{
		class: "col-1 h-[80px] ml-[26.36px] mt-[7.3px] relative row-1 w-[35px]",
		svg: OurStorySvgs.OurStorySvg22,
	},
	{
		class: "col-1 h-[14.643px] ml-[44.34px] mt-[52.57px] relative row-1 w-[5.328px]",
		svg: OurStorySvgs.OurStorySvg23,
	},
	{
		class: "col-1 h-[20.341px] ml-[44.78px] mt-[50.24px] relative row-1 w-[6.673px]",
		svg: OurStorySvgs.OurStorySvg24,
	},
	{
		class: "col-1 h-[16.853px] ml-[47.23px] mt-[50.93px] relative row-1 w-[6.549px]",
		svg: OurStorySvgs.OurStorySvg25,
	},
	{
		class: "col-1 h-[12.099px] ml-[37.75px] mt-[57.77px] relative row-1 w-[6.095px]",
		svg: OurStorySvgs.OurStorySvg26,
	},
	{
		class: "col-1 h-[17.947px] ml-[42.05px] mt-[50.62px] relative row-1 w-[6.145px]",
		svg: OurStorySvgs.OurStorySvg27,
	},
	{
		class: "col-1 h-[12.801px] ml-[40.75px] mt-[57.54px] relative row-1 w-[7.035px]",
		svg: OurStorySvgs.OurStorySvg28,
	},
	{
		class: "col-1 h-[89.044px] ml-[40.11px] mt-0 relative row-1 w-[29.711px]",
