	},
	{
		style: "left: 6.1px; top: 42.37px; width: 100.296px; height: 43.183px;",
		svg: OurStorySvgs.OurStorySvg43,
	},
];
const activeStoryIndex = 0;
---

<Layout title="Our Story">
	<div
		class="bg-white flex flex-col items-start relative w-full"
		data-name="Our Story">
		<section class="relative w-full" data-name="Wireframe - 53">
			<ContentContainer size="wide" class="h-full">
				<div
					class="relative grid w-full min-h-[540px] max-w-[913px] mt-20 mx-auto items-center gap-8 md:grid-cols-[minmax(0,570px)_279px] md:gap-16">
					<p class={`${typeStyles.heroTitleLarge} text-green-800`}>
						Farm to Feed began with a simple but urgent idea
					</p>
					<p class={`${typeStyles.bodyLarge} text-green-500`}>
						tackling food loss in Kenya's fresh produce supply
						chain. We introduced grade rescue to the Nairobi market,
						creating a pathway for vegetables that might otherwise
						go to waste.
					</p>
				</div>
			</ContentContainer>
			<div class="relative" data-name="our-story-divider">
				<img
					alt=""
					aria-hidden="true"
					class="w-full h-full object-cover"
					src={ourStoryDividerUrl}
				/>
				<div
					class="absolute hidden h-[198px] right-50 top-0 w-[203.25px] md:block"
					data-name="Group">
					<Fragment set:html={OurStorySvgs.OurStorySvg46} />
				</div>
			</div>
		</section>
		<section
			class="bg-white overflow-clip relative w-full"
			data-name="Wireframe - 10">
			<ContentContainer size="wide" class="h-full">
				<div
					class="relative flex h-full flex-col items-center min-h-[540px] max-w-[760px] mt-20 mx-auto gap-8 md:gap-16">
					<p
						class={`${typeStyles.sectionTitle} not-italic text-[#0f251b] text-center w-full max-w-148`}>
						Connecting production to dependable demand...
					</p>
					<div
						class={`${typeStyles.body} mt-[24px] md:mt-[55px] not-italic text-[#0f251b] text-center w-full max-w-148`}>
						<p class="leading-copy">
							As we worked alongside our customers and farmers, we
							quickly learned that food loss is one part of a much
							larger challenge. Farmers needed more than a
							solution for imperfect and surplus produce. They
							needed�reliable market access for their full
							harvest.
						</p>
						<p class="leading-copy">
							Since those early days, Farm to Feed has grown into
							a trusted off taker and partner for farmers, helping
							to address one of Kenya�s most persistent
							agricultural bottlenecks: connecting production to
							dependable demand.
						</p>
					</div>
					<div
						class="grid w-full gap-12 mb-24 items-start justify-items-center md:grid-cols-2 md:gap-16 md:mb-40">
						{
							storyPrinciples.map((principle) => (
								<article class="relative w-full max-w-[351px] text-center">
									<div class="pointer-events-none absolute left-1/2 top-0 z-20 -translate-x-1/2 select-none">
										{principle.icon === "vision" ? (
											<div class="relative h-[124px] w-[127.288px]">
												<Fragment
													set:html={
														OurStorySvgs.OurStorySvg01
													}
												/>
												<div
													class="absolute left-[39.9px] top-[29.59px] h-[64.416px] w-[57.169px]"
													data-name="Isolation_Mode">
													<Fragment
														set:html={
															OurStorySvgs.OurStorySvg02
														}
													/>
												</div>
											</div>
										) : (
											<div class="relative h-[124px] w-[127.221px]">
												<div class="flex h-[124px] items-center justify-center">
													<div class="-scale-y-100 flex-none rotate-180">
														<div
															class="h-[124px] relative w-[127.221px]"
															data-name="Vector">
															<Fragment
																set:html={
																	OurStorySvgs.OurStorySvg03
																}
															/>
														</div>
													</div>
												</div>
												<div
													class="absolute left-[26.17px] top-[41.87px] h-[51.532px] w-[74.883px] overflow-clip"
													data-name="Isolation_Mode">
													<div
														class="absolute inset-[-0.01%_-0.02%_-0.02%_0]"
														data-name="Vector">
														<Fragment
															set:html={
																OurStorySvgs.OurStorySvg04
															}
														/>
													</div>
												</div>
											</div>
										)}
									</div>
									<div class="relative pt-10">
										<div
											class="pointer-events-none absolute inset-x-0 top-[48px] z-0 mx-auto w-full max-w-[351px] select-none"
											data-name="Vector">
											<div class="relative h-[336px] w-full">
												<div class="absolute inset-[-1.19%_-7.92%_-13.1%_-7.92%]">
													<Fragment
														set:html={
															OurStorySvgs.OurStorySvg47
														}
													/>
												</div>
											</div>
										</div>
										<div class="relative z-10 flex min-h-[336px] flex-col items-center px-8 pb-10 pt-[104px] md:min-h-[348px] md:px-12 md:pb-12 md:pt-[108px]">
											<div class="flex max-w-[248px] flex-col items-center gap-5 text-center not-italic">
												<p
													class={`${typeStyles.body} text-[#85a687]`}>
													{principle.label}
												</p>
												<p
													class={`${typeStyles.cardTitle} leading-tight text-[#0f251b] w-full`}>
													{principle.body}
												</p>
											</div>
										</div>
									</div>
								</article>
							))
						}
					</div>
				</div>
			</ContentContainer>
			<div
				class="-translate-x-1/2 -translate-y-1/2 absolute hidden h-[601px] left-[33.5px] top-[calc(20%+266px)] w-[441px] lg:block"
				data-name="Vector">
				<img
					alt=""
					class="absolute block inset-0 max-w-none size-full"
					height="601"
					src={storyIllustrationOneUrl}
					width="441"
				/>
			</div>
			<div
				class="-translate-x-1/2 -translate-y-1/2 absolute hidden h-[601px] items-center justify-center left-[calc(100%-46.5px)] top-[calc(20%+369px)] w-[441px] lg:flex">
				<div class="-scale-y-100 flex-none rotate-180">
					<div
						class="h-[601px] relative w-[441px]"
						data-name="Vector">
						<img
							alt=""
							class="absolute block inset-0 max-w-none size-full"
							height="601"
							src={storyIllustrationTwoUrl}
							width="441"
						/>
					</div>
				</div>
			</div>
		</section>
		<section
			class="bg-white min-h-[500px] md:min-h-[580px] overflow-clip relative w-full mb-24"
			data-name="Wireframe - 54">
			<ContentContainer size="wide">
				<div
					class="relative flex flex-col items-center gap-16 md:gap-[124px]">
					<div
						class="absolute hidden md:flex h-[87px] items-center justify-center left-1/2 -translate-x-1/2 top-58 w-[485px]"
						style="container-type:size">
						<div class="flex-none h-[100cqw] rotate-90 w-[100cqh]">
							<div class="relative size-full" data-name="Vector">
								<Fragment
									set:html={OurStorySvgs.OurStorySvg48}
								/>
							</div>
						</div>
					</div>
					<div
						class="flex flex-col items-center relative w-full max-w-[758px]">
						<p
							class={`${typeStyles.sectionTitle} not-italic relative text-[#030806] text-center w-full`}>
							Farm to Feed is the tech-enabled platform
						</p>
					</div>
					<div
						class="grid gap-12 md:grid-cols-3 md:gap-8 items-start relative w-full max-w-[952px]">
						{
							platformSteps.map((step) => (
								<div
									class={`flex flex-col items-center relative w-full ${step.title ? "gap-8 md:gap-14" : "pt-[25px]"}`}>
									{step.illustration === "farmers" ? (
										<div class="h-[198.445px] relative w-[203.707px]">
											<Fragment
												set:html={
													OurStorySvgs.OurStorySvg05
												}
											/>
										</div>
									) : step.illustration === "platform" ? (
										<div class="h-[198.445px] relative w-[203.707px]">
											<Fragment
												set:html={
													OurStorySvgs.OurStorySvg06
												}
											/>
										</div>
									) : (
										<div class="relative h-[198.445px] w-[203.707px]">
											<div
												class="absolute inset-0"
												data-name="Vector">
												<Fragment
													set:html={
														OurStorySvgs.OurStorySvg07
													}
												/>
											</div>
											<div
												class="absolute left-[93px] top-[21px] h-[37.983px] w-[27px]"
												data-name="Vector">
												<Fragment
													set:html={
														OurStorySvgs.OurStorySvg08
													}
												/>
											</div>
											<div
												class="absolute left-[46.64px] top-[63.7px] h-[89.044px] w-[113.379px]"
												data-name="Group">
												{customerIllustrationSvgs.map(
													(item) => (
														<div
															class="absolute"
															style={item.style}
															data-name="Vector">
															<Fragment
																set:html={
																	item.svg
																}
															/>
														</div>
													),
												)}
												<div class="absolute left-[70.36px] top-[24.07px] flex h-[57.474px] w-[30.966px] items-center justify-center">
													<div class="-scale-y-100 flex-none rotate-180">
														<div class="h-[57.474px] relative w-[30.966px]">
															<Fragment
																set:html={
																	OurStorySvgs.OurStorySvg34
																}
															/>
														</div>
													</div>
												</div>
												<div
													class="absolute left-[46.36px] top-[12.3px] flex h-[60.714px] w-[41.077px] items-center justify-center"
													style="--transform-inner-width: 1185; --transform-inner-height: 21;">
													<div class="flex-none rotate-[-11.76deg]">
														<div class="h-[55.694px] relative w-[30.361px]">
															<Fragment
																set:html={
																	OurStorySvgs.OurStorySvg41
																}
															/>
														</div>
													</div>
												</div>
												<div
													class="absolute left-0 top-[66.85px] flex h-[26.716px] w-[113.379px] items-center justify-center"
													style="--transform-inner-width: 1185; --transform-inner-height: 21;">
													<div class="-scale-y-100 flex-none rotate-[177.8deg]">
														<div
															class="h-[22.402px] relative w-[112.601px]"
															data-name="Vector">
															<Fragment
																set:html={
																	OurStorySvgs.OurStorySvg44
																}
															/>
														</div>
													</div>
												</div>
											</div>
										</div>
									)}
									{step.title && step.body && (
										<div class="flex flex-col gap-6 items-start not-italic relative text-black text-center w-full">
											<p
												class={`${typeStyles.cardTitle} relative w-full`}>
												{step.title}
											</p>
											<p
												class={`${typeStyles.body} relative w-full`}>
												{step.body}
											</p>
										</div>
									)}
								</div>
							))
						}
					</div>
				</div>
			</ContentContainer>
		</section>
		<section
			class="min-h-[600px] md:min-h-[750px] overflow-clip relative w-full"
			data-name="Story"
			data-story-timeline
			data-slides={JSON.stringify(storySlides)}>
			<ContentContainer size="wide" class="relative z-10 pb-64">
				<div class="relative flex flex-col items-center gap-16">
					<p
						class={`${typeStyles.heroTitleLarge} text-green-800 text-center w-full max-w-[544px]`}>
						Our story
					</p>
					<p
						class={`${typeStyles.body} not-italic text-black text-center`}>
						Slide the carrot across the timeline or tap to learn
						about our journey
					</p>
					<div
						class="relative flex flex-col items-center gap-20 w-full"
						data-name="slider">
						<div
							class="relative h-[65px] w-full max-w-[607px]"
							data-name="slider-field"
							data-slider-field
							style="touch-action: none;">
							<div
								class="absolute h-[32px] left-0 right-0 top-[3px]"
								data-name="slider-base">
								<Fragment
									set:html={OurStorySvgs.OurStorySvg52}
								/>
							</div>
							<div
								class="-translate-x-1/2 absolute z-20 flex isolate items-start justify-between left-[calc(50%-4px)] top-0 w-[82%] max-w-[499px]"
								data-name="milestones"
								data-milestones>
								{
									storySlides.map((milestone, index) => (
										<button
											aria-current={
												index === activeStoryIndex
													? "step"
													: undefined
											}
											aria-label={`Show ${milestone.label} story`}
											class="cursor-pointer flex flex-col gap-[5px] items-center relative rounded-[8px] bg-transparent p-0 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#747c50]"
											data-name="milestone"
											data-story-index={index}
											style={`width: ${milestone.width}px; z-index: ${milestone.zIndex};`}
											type="button">
											{" "}
											<div class="bg-[#4c352b] h-[36px] relative rounded-[8px] w-[3px]" />{" "}
											<p
												class={`${typeStyles.caption} font-normal not-italic relative text-black whitespace-nowrap`}>
												{" "}
												{milestone.label}{" "}
											</p>{" "}
											<div
