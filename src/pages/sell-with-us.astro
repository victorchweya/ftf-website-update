  <script>
    const storyRoot = document.querySelector("[data-supplier-stories]");
    if (storyRoot) {
      const storyData = storyRoot.querySelector("[data-supplier-story-data]");
      const stories = JSON.parse(storyData?.textContent || "[]");
      const desktopCards = Array.from(
        storyRoot.querySelectorAll("[data-story-card]"),
      );
      const mobileCard = storyRoot.querySelector("[data-mobile-story-card]");
      const total = stories.length;
      let activeIndex = 1;
      let timer = null;
      const getStoryAtOffset = (offset) => {
        const storyIndex = (activeIndex + offset + total) % total;
        return stories[storyIndex];
      };
      const render = () => {
        if (!total) return;
        desktopCards.forEach((card) => {
          const offset = Number(card.getAttribute("data-story-offset") || "0");
          const story = getStoryAtOffset(offset);
          card.setAttribute("aria-hidden", offset !== 0 ? "true" : "false");
          card.classList.toggle("hidden", offset !== 0);
          card.classList.toggle("lg:block", offset !== 0);
          card.style.left =
            offset === 0 ? "50%" : offset < 0 ? "-320px" : "calc(100% - 320px)";
          card.style.transform = offset === 0 ? "translateX(-50%)" : "none";
          if (story) {
            card.innerHTML = story.html;
          }
        });
        if (mobileCard) {
          const story = getStoryAtOffset(0);
          mobileCard.innerHTML = story?.html || "";
        }
      };
      const go = (direction) => {
        activeIndex = (activeIndex + direction + total) % total;
        render();
      };
      const restartAutoplay = () => {
        if (timer) window.clearInterval(timer);
        timer = window.setInterval(() => go(1), 3000);
      };
      storyRoot
        .querySelector("[data-story-prev]")
        ?.addEventListener("click", () => {
          go(-1);
          restartAutoplay();
        });
      storyRoot
        .querySelector("[data-story-next]")
        ?.addEventListener("click", () => {
          go(1);
          restartAutoplay();
        });
      render();
      restartAutoplay();
    }
  </script>
</Layout>
