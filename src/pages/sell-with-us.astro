---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
import ContentContainer from "../components/layout/ContentContainer.astro";
import OptimizedImage from "../components/OptimizedImage.astro";
import KenyanBuyersArrow1Svg from "../components/figma/KenyanBuyersArrow1Svg.astro";
import KenyanBuyersArrow2Svg from "../components/figma/KenyanBuyersArrow2Svg.astro";
import KenyanBuyersArrow3Svg from "../components/figma/KenyanBuyersArrow3Svg.astro";
import BorderBottomKenyanBuyersSvg from "../components/figma/BorderBottomKenyanBuyersSvg.astro";
import KenyanBuyersTestimonialBackgroundSvg from "../components/figma/KenyanBuyersTestimonialBackgroundSvg.astro";
import KenyanBuyersTestimonialBeansSvg from "../components/figma/KenyanBuyersTestimonialBeansSvg.astro";
import KenyanBuyersTestimonialProduceSvg from "../components/figma/KenyanBuyersTestimonialProduceSvg.astro";
import KenyanBuyersTestimonialProductBundleSvg from "../components/figma/KenyanBuyersTestimonialProductBundleSvg.astro";
import LocalBuyerTestimonialCard from "../components/LocalBuyerTestimonialCard.astro";
import LocalBuyerTestimonialDecor from "../components/LocalBuyerTestimonialDecor.astro";
import * as SellWithUsSvgs from "../lib/figmaMarkup/sellWithUsSvgs";
import {
	Frame26,
	Frame27,
	Frame31,
	Frame35,
	Frame43,
} from "../lib/figmaMarkup/sellWithUs";
import supplierStoryPrimaryImage from "../assets/figma/sell-with-us/supplier-story-1.png";
import supplierStorySecondaryImage from "../assets/figma/sell-with-us/supplier-story-2.png";
import BottomLandscapeSvg from "../components/figma/BottomLandscapeSvg.astro";
import BackgroundBottomImpactSvg from "../components/figma/BackgroundBottomImpactSvg.astro";
import SellWithUsDecorBlobSvg from "../components/figma/SellWithUsDecorBlobSvg.astro";
import SellWithUsDecorPlantOneSvg from "../components/figma/SellWithUsDecorPlantOneSvg.astro";
import SellWithUsDecorPlantTwoSvg from "../components/figma/SellWithUsDecorPlantTwoSvg.astro";
import SellWithUsDecorPlantThreeSvg from "../components/figma/SellWithUsDecorPlantThreeSvg.astro";

import { sectionSpacing, typeStyles } from "../lib/figmaStyles";
import paymentIcon from "../assets/figma/sell-with-us/payment.svg?url";
import reachoutIcon from "../assets/figma/sell-with-us/reachout.svg?url";
import sortedIcon from "../assets/figma/sell-with-us/sorted.svg?url";
import sourceIcon from "../assets/figma/sell-with-us/source.svg?url";
const offeringRows = [
	[
		{
			Header: Frame26,
			body: "Since 2020, we have been giving farmers consistent market access for all fresh value chains.",
		},
		{
			Header: Frame27,
			body: "We pay within three days of accepting the produce.",
		},
		{
			Header: Frame31,
			body: "Whether grade 1, 2 or imperfect, we buy all your product grades, as long as they are fresh.",
		},
	],
	[
		{
			Header: Frame35,
			body: "We work with our FTF aggregators, making us the most reliable partner, also for small quantities.",
		},
		{
			Header: Frame43,
			body: "Our mobile app gives you full transparency into all your orders, including your transaction history.",
		},
	],
];
const supplierTestimonials = [
	{
		company: "Farmer",
		name: "Peter",
		quote: "I've traded with Farm to Feed for the last two years. Their training, app transparency, and reliable payments have helped me reduce rejected produce and track every order.",
	},
	{
		company: "Farmer",
		name: "Jane",
		quote: "My collaboration with Farm to Feed has improved income, strengthened market access, and offered fair prices to our farmer community.",
	},
	{
		company: "Farmer",
		name: "Jane",
		quote: "The partnership has reduced post-harvest losses, created youth jobs, empowered women farmers, and strengthened local food security.",
	},
];
const localBuyerHowItWorksSteps = [
	{
		body: "Reach out to our Sourcing team and download our mobile app to become a Farm to Feed supplier.",
		color: "#8C98EE",
		icon: reachoutIcon,
		textColor: "#e6e6e6",
	},
	{
		body: "We source your full fresh harvest, from grade 1 to imperfect produce. All orders are placed in our mobile app for full transparency.",
		color: "#A35380",
		icon: sourceIcon,
		textColor: "#e6e6e6",
	},
	{
		body: "All produce is received, sorted and graded in our warehouse. You can track the progress real time in your app.",
		color: "#85A687",
		icon: sortedIcon,
		textColor: "#e6e6e6",
	},
	{
		body: "Your payment is done within three days of receiving the produce. From the app, you can download your statement.",
		color: "#EBC194",
		icon: paymentIcon,
		textColor: "#2b1a08",
	},
];
const localBuyerHowItWorksDesktopLayout = [
	{
		copyClass: "max-w-[205px]",
		iconClass: "left-[0%] top-[128px] h-[200px] w-[206px]",
		textClass: "left-[0%] top-[352px] w-[330px]",
	},
	{
		copyClass: "max-w-[220px]",
		iconClass: "left-[260px] top-0 h-[200px] w-[205px]",
		textClass: "left-[500px] top-[0px] w-[320px]",
	},
	{
		copyClass: "max-w-[245px]",
		iconClass: "left-[508px] top-[222px] h-[202px] w-[207px]",
		textClass: "left-[580px] top-[444px] w-[360px]",
	},
	{
		copyClass: "max-w-[255px]",
		iconClass: "right-[78px] top-[30px] h-[200px] w-[205px]",
		textClass: "right-[0px] top-[252px] w-[300px]",
	},
];
const transformSizeStyle =
	"--transform-inner-width: 1185; --transform-inner-height: 21;";
---

<Layout title="Sell With Us">
	<div
		class="bg-olive-100 flex flex-col items-center relative w-full min-h-screen"
		data-name="Sell with us">
		<div
			class="bg-olive-100 min-h-[600px] md:min-h-[1034px] overflow-clip relative w-full"
			data-name="Wireframe - 44">
			<ContentContainer
				size="wide"
				class="pt-[170px] pb-30 md:pt-[260px]">
				<div class="flex flex-col gap-10 items-center relative">
					<div
						class="flex flex-col gap-8 md:gap-16 items-center relative px-4">
						<div
							class="absolute h-[36px] left-[6px] top-[124px] w-[633px]"
							data-name="objects">
						</div>
						<div
							class={`${typeStyles.heroTitleLarge} not-italic relative text-black text-center w-full`}>
							<p class="mb-0 text-[#0f251b]">Making farming</p>
							<p class="text-green-500">Fair and Rewarding</p>
						</div>
						<div
							class={`${typeStyles.body} not-italic relative text-green-500 text-sm md:text-base text-center w-full max-w-[656px]`}>
							<p class="leading-copy mb-0">
								{
									`We want to keep your hard work in the human food chain, making sure nothing goes to waste. With us, it's easy to access the market and sell your entire harvest -including the odd-shaped and surplus produce- at fair price.`
								}
							</p>
							<p class="leading-copy">
								{``}
								<br aria-hidden="true" /> Throughout Kenya, we are
								the buyer of choice for farmers like you.
							</p>
						</div>
					</div>
					<Button href="#how-it-works" size="lg" variant="primary">
						See how it works
					</Button>
				</div>
			</ContentContainer>
			<div
				class="absolute hidden h-[400px] md:block md:h-[601px] -left-[100px] md:-left-[150px] top-[calc(20%-150px)] md:top-[calc(20%-163.5px)] w-[300px] md:w-[441px] opacity-30 md:opacity-100"
				data-name="Vector">
				<OptimizedImage
					alt=""
					class="absolute block inset-0 max-w-none size-full"
					height="601"
					sizes="441px"
					src={supplierStoryPrimaryImage}
					widths={[300, 441]}
					width="441"
				/>
			</div>
			<div
				class="absolute hidden h-[400px] md:flex md:h-[601px] items-center justify-center -right-[100px] md:-right-[150px] top-[calc(20%-150px)] md:top-[calc(20%-60.5px)] w-[300px] md:w-[441px] opacity-30 md:opacity-100">
				<div class="-scale-y-100 flex-none rotate-180">
					<div
						class="h-[601px] relative w-[441px]"
						data-name="Vector">
						<OptimizedImage
							alt=""
							class="absolute block inset-0 max-w-none size-full"
							height="601"
							sizes="441px"
							src={supplierStorySecondaryImage}
							widths={[300, 441]}
							width="441"
						/>
					</div>
				</div>
			</div>
			<BottomLandscapeSvg
				className=" w-full max-w-none pointer-events-none select-none"
			/>
		</div>
		<div class="bg-olive-100 relative w-full" data-name="Wireframe - 55">
			<ContentContainer size="wide" class="py-24">
				<div
					class="grid gap-8 items-center justify-items-center relative w-full">
					<div
						class="grid gap-8 items-center justify-items-center relative w-full">
						<div
							class="flex flex-col gap-8 items-center justify-items-center max-w-[1052px] mx-auto not-italic relative text-center w-full">
							<p
								class={`${typeStyles.heroTitle} relative text-[#0f251b] w-full`}>
								Our Offering
							</p>
							<p
								class={`${typeStyles.body} relative text-orange-500 w-full`}>
								Farmers who supply to Farm to Feed enjoy:
							</p>
						</div>
						{
							offeringRows.map((row, rowIndex) => (
								<div
									class={`relative w-full mx-auto ${rowIndex === 1 ? "max-w-[842px]" : ""}`}>
									<div
										class={`grid gap-8 items-start justify-center relative w-full ${rowIndex === 0 ? "lg:grid-cols-3" : "md:grid-cols-2"}`}>
										{row.map((offering) => {
											const OfferingHeader =
												offering.Header;
											return (
												<div class="bg-[#fbfafa] relative rounded-[30px] w-full">
													<div class="flex flex-col gap-[27px] items-start p-[28px] md:p-[48px] relative size-full">
														<Fragment
															set:html={
																OfferingHeader
															}
														/>
														<p
															class={`${typeStyles.body} relative text-green-500 w-full`}>
															{offering.body}
														</p>
													</div>
												</div>
											);
										})}
									</div>
								</div>
							))
						}
					</div>
				</div>
			</ContentContainer>
		</div>
		<BackgroundBottomImpactSvg className="w-full bg-white" fill="#f3f5e7" />
		<section
			id="how-it-works"
			class="bg-white overflow-clip relative w-full">
			<ContentContainer size="wide" class="relative z-10 pb-24">
				<div class="mx-auto max-w-148 text-center">
					<p
						class={`${typeStyles.sectionTitleLarge} mt-30 not-italic text-[#0f251b] w-full`}>
						How does it work?
					</p>
					<p
						class={`${typeStyles.body} mt-2 not-italic text-green-500 w-full`}>
						From joining as a supplier to getting paid, here’s how
						farmers sell their harvest with Farm to Feed.
					</p>
				</div>
				<div class="mt-[56px] grid gap-8 sm:grid-cols-2 xl:hidden">
					{
						localBuyerHowItWorksSteps.map((step, index) => (
							<div class="flex flex-col gap-6 items-center rounded-3xl bg-white p-4 text-center">
								<div class="relative h-45 w-46.25 ">
									<img
										alt=""
										aria-hidden="true"
										class="size-full object-contain"
										src={step.icon}
									/>
								</div>
								<div class="flex gap-4 items-start text-left w-full max-w-[280px]">
									<div
										class={`${typeStyles.body} flex size-10 items-center justify-center rounded-full font-medium leading-normal`}
										style={`background-color: ${step.color}; color: ${step.textColor};`}>
										{index + 1}
									</div>
									<div class="flex flex-col gap-[12px] items-start not-italic relative w-full">
										<p
											class={`${typeStyles.caption} relative text-green-500 w-full`}>
											{step.body}
										</p>
									</div>
								</div>
							</div>
						))
					}
				</div>
				<div
					class="relative mx-auto mt-[64px] hidden min-h-[540px] max-w-[1180px] xl:block">
					<div class="relative min-h-[540px] w-full">
						{
							localBuyerHowItWorksSteps.map((step, index) => {
								const layout =
									localBuyerHowItWorksDesktopLayout[index];
								return (
									<article class="contents">
										<div
											class={`absolute ${layout.iconClass}`}
											data-name="media">
											<img
												alt=""
												aria-hidden="true"
												class="size-full object-contain"
												src={step.icon}
											/>
										</div>
										<div
											class={`absolute flex gap-4 items-start ${layout.textClass}`}>
											<div
												class={`${typeStyles.body} flex size-10 shrink-0 items-center justify-center rounded-full font-medium leading-normal`}
												style={`background-color: ${step.color}; color: ${step.textColor};`}>
												{index + 1}
											</div>
											<div
												class={`flex flex-col gap-4 items-start not-italic relative w-full ${layout.copyClass}`}>
												<p
													class={`${typeStyles.caption} relative text-green-500 w-full`}>
													{step.body}
												</p>
											</div>
										</div>
									</article>
								);
							})
						}
						<div class="pointer-events-none absolute inset-0">
							<div
								class="absolute left-[108px] top-[16px] h-[145.923px] w-[143.362px]">
								<KenyanBuyersArrow1Svg class="size-full" />
							</div>
							<div
								class="absolute left-[385px] top-[218px] h-[138.813px] w-[110.247px]">
								<KenyanBuyersArrow2Svg class="size-full" />
							</div>
							<div
								class="absolute right-80 top-40 h-[94.387px] w-[129.822px]">
								<KenyanBuyersArrow3Svg class="size-full" />
							</div>
						</div>
					</div>
				</div>
				<div class="mt-12 flex justify-center">
					<div
						class="h-[70.87px] relative w-[238.96px]"
						data-name="GetItOnGooglePlay_Badge_Web_color_English 1">
						<Fragment set:html={SellWithUsSvgs.SellWithUsSvg01} />
					</div>
				</div>
			</ContentContainer>
		</section>
		<section
			class="bg-[#f3f5e7] min-h-[600px] md:min-h-[750px] overflow-clip relative rounded-bl-[40px] rounded-br-[40px] w-full"
			data-name="Testimonial"
			data-supplier-testimonials>
			<ContentContainer
				size="wide"
				class="py-24 md:py-54 relative z-10 flex flex-col items-center gap-[56px] md:gap-[80px]">
				<p
					class={`${typeStyles.sectionTitleLarge} not-italic text-[#0f251b] text-center w-full max-w-[800px]`}>
					Discover how farmers are transforming communities
				</p>
				<div
					class="relative grid w-full max-w-[calc(100vw-40px)] grid-cols-2 justify-items-center gap-6 sm:max-w-[640px] lg:mx-auto lg:w-fit lg:max-w-none lg:grid-cols-[auto_minmax(0,640px)_auto] lg:items-center lg:gap-10">
					<button
						aria-label="Show previous farmer story"
						class="group order-2 justify-self-end rounded-[40px] bg-transparent border-0 p-0 transition-transform duration-200 hover:-translate-y-0.5 focus-visible:-translate-y-0.5 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#747c50] lg:order-none lg:justify-self-auto"
						data-story-prev
						type="button">
						<div
							class="content-stretch flex items-start p-[12px] relative rounded-[40px] shrink-0 transition-colors duration-200 group-hover:bg-white/60 group-focus-visible:bg-white/60"
							data-name="order">
							<div
								aria-hidden="true"
								class="absolute border border-[#747c50] border-solid inset-0 pointer-events-none rounded-[40px] transition-colors duration-200 group-hover:border-[#0f251b] group-focus-visible:border-[#0f251b]">
							</div>
							<div
								class="overflow-clip relative shrink-0 size-[24px]"
								data-name="arrow-left">
								<div
									class="absolute inset-[20.83%]"
									data-name="Icon">
									<div class="absolute inset-[-7.14%]">
										<svg
											aria-hidden="true"
											class="block size-full"
											fill="none"
											preserveAspectRatio="none"
											viewBox="0 0 16 16">
											<path
												class="transition-colors duration-200 group-hover:stroke-[#0f251b] group-focus-visible:stroke-[#0f251b]"
												d="M15 8H1M8 1L1 8L8 15"
												stroke="var(--stroke-0, #747C50)"
												stroke-linecap="round"
												stroke-linejoin="round"
												stroke-width="2">
											</path>
										</svg>
									</div>
								</div>
							</div>
						</div>
					</button>
					<div
						class="relative order-1 col-span-2 w-full min-w-0 max-w-[calc(100vw-40px)] justify-self-center sm:max-w-[640px] lg:order-none lg:col-span-1">
						<div
							class="swiper w-full overflow-hidden lg:!overflow-visible"
							data-supplier-testimonial-swiper>
							<div class="swiper-wrapper">
								{
									supplierTestimonials.map((testimonial) => (
										<div class="swiper-slide !h-auto">
											<LocalBuyerTestimonialCard
												company={testimonial.company}
												name={testimonial.name}
												quote={testimonial.quote}
											/>
										</div>
									))
								}
							</div>
						</div>
						<LocalBuyerTestimonialDecor />
					</div>
					<button
						aria-label="Show next farmer story"
						class="group order-3 justify-self-start rounded-[40px] bg-transparent border-0 p-0 transition-transform duration-200 hover:-translate-y-0.5 focus-visible:-translate-y-0.5 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#747c50] lg:order-none lg:justify-self-auto"
						data-story-next
						type="button">
						<div
							class="content-stretch flex items-start p-[12px] relative rounded-[40px] shrink-0 transition-colors duration-200 group-hover:bg-white/60 group-focus-visible:bg-white/60"
							data-name="order">
							<div
								aria-hidden="true"
								class="absolute border border-[#747c50] border-solid inset-0 pointer-events-none rounded-[40px] transition-colors duration-200 group-hover:border-[#0f251b] group-focus-visible:border-[#0f251b]">
							</div>
							<div
								class="overflow-clip relative shrink-0 size-[24px]"
								data-name="arrow-right">
								<div
									class="absolute inset-[20.83%]"
									data-name="Icon">
									<div class="absolute inset-[-7.14%]">
										<svg
											aria-hidden="true"
											class="block size-full"
											fill="none"
											preserveAspectRatio="none"
											viewBox="0 0 16 16">
											<path
												class="transition-colors duration-200 group-hover:stroke-[#0f251b] group-focus-visible:stroke-[#0f251b]"
												d="M1 8H15M8 15L15 8L8 1"
												stroke="var(--stroke-0, #747C50)"
												stroke-linecap="round"
												stroke-linejoin="round"
												stroke-width="2">
											</path>
										</svg>
									</div>
								</div>
							</div>
						</div>
					</button>
				</div>
			</ContentContainer>
			<div
				class="absolute hidden h-[137.947px] items-center justify-center left-[calc(75%+23.37px)] top-[231.07px] w-[206.385px] lg:flex"
				style="--transform-inner-width: 1185; --transform-inner-height: 21;">
				<div class="flex-none rotate-[-15.41deg]">
					<div class="h-[91px] relative w-[189px]" data-name="Capa_1">
						<KenyanBuyersTestimonialBeansSvg
							class="absolute block inset-0 size-full"
						/>
					</div>
				</div>
			</div>
			<div
				class="absolute hidden h-[307.61px] items-center justify-center left-[31px] top-[160px] w-[332.171px] lg:flex"
				style="--transform-inner-width: 1185; --transform-inner-height: 252;">
				<div class="flex-none rotate-[38.46deg]">
					<KenyanBuyersTestimonialProduceSvg
						class="h-[151.494px] overflow-clip w-[303.868px]"
					/>
				</div>
			</div>
			<div
				class="absolute hidden h-[858px] items-center justify-center left-[-2.92%] right-[-1.39%] top-[-767px] lg:flex"
				style="container-type:size">
				<div
					class="-scale-x-100 flex-none h-[100cqw] rotate-90 w-[100cqh]">
					<div class="relative size-full" data-name="Vector">
						<KenyanBuyersTestimonialBackgroundSvg
							class="absolute block inset-0 size-full"
						/>
					</div>
				</div>
			</div>
			<div
				class="absolute hidden h-[203.64px] items-center justify-center left-[128px] top-[561px] w-[245.05px] lg:flex"
				style="--transform-inner-width: 1185; --transform-inner-height: 105;">
				<div class="flex-none rotate-[34.14deg]">
					<KenyanBuyersTestimonialProductBundleSvg
						class="h-[83.796px] overflow-clip w-[239.258px]"
					/>
				</div>
			</div>
		</section>
		<div
			class="bg-green-500 relative overflow-hidden
		w-full border-b border-dotted border-green-400 rounded-tl-4xl rounded-tr-4xl"
			data-name="Wireframe - 36">
			<div class="relative">
				<div
					class="absolute h-[265.41px] left-[calc(83.33%-80.33px)] opacity-28 top-[328px] w-[361.514px]">
					<div
						class="absolute bottom-0 h-[265.41px] right-0 w-[361.514px]"
						data-name="Group">
						<SellWithUsDecorBlobSvg
							class="absolute block inset-0 size-full"
						/>
					</div>
				</div>
				<div
					class="absolute h-[423.454px] left-[139px] opacity-28 top-[267px] w-[381.093px]">
					<div
						class="absolute bottom-0 flex h-[423.454px] items-center justify-center left-0 w-[381.093px]"
						style={transformSizeStyle}>
						<div class="flex-none rotate-[-29.12deg]">
							<div
								class="h-[350.48px] relative w-[240.979px]"
								data-name="Group">
								<SellWithUsDecorPlantOneSvg
									class="absolute block inset-0 size-full"
								/>
							</div>
						</div>
					</div>
				</div>
