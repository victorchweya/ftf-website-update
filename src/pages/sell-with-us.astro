---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
import ContentContainer from "../components/layout/ContentContainer.astro";
import * as SellWithUsSvgs from "../lib/figmaMarkup/sellWithUsSvgs";
import {
  Frame26,
  Frame27,
  Frame31,
  Frame35,
  Frame43,
  Group22,
  Group24,
  Group23,
} from "../lib/figmaMarkup/sellWithUs";
import { Order4, Order5 } from "../lib/figmaMarkup/buyFromUsLocal";
import supplierStoryPrimaryImage from "../assets/figma/sell-with-us/supplier-story-1.png?url";
import supplierStorySecondaryImage from "../assets/figma/sell-with-us/supplier-story-2.png?url";
import { supplierStoryMask } from "../lib/figmaMarkup/sellWithUsMask";
import BottomLandscapeSvg from "../components/figma/BottomLandscapeSvg.astro";
import { sectionSpacing, typeStyles } from "../lib/figmaStyles";
const offeringRows = [
  [
    {
      Header: Frame26,
      body: "Since 2020, we have been giving farmers consistent market access for all fresh value chains.",
    },
    {
      Header: Frame27,
      body: "We pay within three days of accepting the produce.",
    },
    {
      Header: Frame31,
      body: "Whether grade 1, 2 or imperfect, we buy all your product grades, as long as they are fresh.",
    },
  ],
  [
    {
      Header: Frame35,
      body: "We work with our FTF aggregators, making us the most reliable partner, also for small quantities.",
    },
    {
      Header: Frame43,
      body: "Our mobile app gives you full transparency into all your orders, including your transaction history.",
    },
  ],
];
const supplierStories = [
  { id: "peter", StoryCard: Group22 },
  { id: "jane-training", StoryCard: Group24 },
  { id: "jane-market-access", StoryCard: Group23 },
  { id: "supplier-community-impact", StoryCard: Group24 },
];
const activeStoryIndex = 1;
const getStoryAtOffset = (offset: number, activeIndex = activeStoryIndex) => {
  const storyCount = supplierStories.length;
  const storyIndex = (activeIndex + offset + storyCount) % storyCount;
  return supplierStories[storyIndex];
};
const visibleSupplierStories = [-1, 0, 1].map((offset) => {
  const story = getStoryAtOffset(offset);
  return {
    ...story,
    offset,
    storyLeft:
      offset === 0 ? "50%" : offset < 0 ? "-320px" : "calc(100% - 320px)",
    storyTransform: offset === 0 ? "translateX(-50%)" : "none",
  };
});
const activeSupplierStory = getStoryAtOffset(0);
const supplierStoryClientData = supplierStories.map(({ id, StoryCard }) => ({
  id,
  html: StoryCard,
}));
const transformSizeStyle =
  "--transform-inner-width: 1185; --transform-inner-height: 21;";
