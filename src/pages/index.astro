---
import HomeSections from "../islands/home-react/HomeSections";
import Layout from "../layouts/Layout.astro";
---

<Layout
	title="Farm to Feed | Shaping the Future of Food"
	description="Farm to Feed connects farmers, markets, and ingredients through smarter supply chains."
	fullWidth>
	<div class="overflow-hidden bg-white">
		<div class="home-react-fonts">
			<HomeSections />
		</div>
	</div>
</Layout>

<style is:global>
	.home-react-fonts,
	.home-react-fonts > [data-name="home"] {
		width: 100%;
	}

	.home-react-fonts > [data-name="home"] {
		align-items: stretch;
		overflow: hidden;
	}

	.home-react-fonts [data-name="Container"],
	.home-react-fonts [data-name="Title"],
	.home-react-fonts [data-name="Row"] {
		max-width: 1280px;
		margin-left: auto;
		margin-right: auto;
	}

	.home-react-fonts [class*="Rubik:"] {
		font-family:
			"Rubik",
			ui-sans-serif,
			system-ui,
			-apple-system,
			BlinkMacSystemFont,
			"Segoe UI",
			sans-serif !important;
	}

	.home-react-fonts [class*="Fraunces:"] {
		font-family: "Fraunces", ui-serif, Georgia, "Times New Roman", serif !important;
	}
</style>
