---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
import ContentContainer from "../components/layout/ContentContainer.astro";
import OptimizedImage from "../components/OptimizedImage.astro";
import heroHomeImage from "../assets/figma/home/hero.png";
import supplyChainImage from "../assets/figma/home/supply-chain-diagram.svg?url";
import farmerMarketImage from "../assets/figma/shared/supply-chain/farmer-market.png";
import businessSourcingImage from "../assets/figma/home/farm-to-feed-produce.png";
import foodSystemsImage from "../assets/figma/home/better-food-systems-everyone.png";
import newsImpactReportImage from "../assets/figma/shared/news/impact-report.png";
import newsStartupAwardImage from "../assets/figma/shared/news/startup-award.png";
import newsOperationsRegionImage from "../assets/figma/shared/news/operations-region.png";
import BackgroundBottomSvg from "../components/figma/BackgroundBottomSvg.astro";
import * as HomeSvgs from "../lib/figmaMarkup/home";
import { sectionSpacing, typeStyles } from "../lib/figmaStyles";
const supplyChainBenefits = [
	{
		title: "Better Markets for Farmers",
		description:
			"We connect farmers to reliable buyers, turning harvests into stable income and reducing unnecessary food loss.",
		image: farmerMarketImage,
		imageAlt: "Produce being loaded for market delivery",
	},
	{
		title: "Better Sourcing for Businesses",
		description:
			"Hotels, caterers, processors, and global buyers access quality produce and ingredients with full transparency and consistent supply.",
		image: businessSourcingImage,
		imageAlt: "Fresh vegetables handed over in a commercial kitchen",
	},
	{
		title: "Better Food Systems for Everyone",
		description:
			"By efficiently matching supply and demand, we ensure more food is consumed rather than wasted. Food systems will shape our planet's future, with Africa leading the way. At Farm to Feed, we create the infrastructure for a more inclusive, resilient, and waste-free future.",
		image: foodSystemsImage,
		imageAlt: "Fresh ingredients arranged on a chopping board",
	},
];
const defaultNewsItems = [
	{
		date: "09 Jan 2026",
		image: newsImpactReportImage,
		title: "Farm to Feed has published their first Impact Report",
	},
	{
		date: "09 Jan 2026",
		image: newsStartupAwardImage,
		title: "Farm to Feed Wins Global Startup Award and Secures New Investment",
	},
	{
		date: "09 Jan 2026",
		image: newsOperationsRegionImage,
		title: "Farm to Feed Expands Operations to New Region",
	},
];
const fallbackImpactMetrics = [
	{ label: "tonnes of CO2e avoided", value: "1K" },
	{ label: "KG of food saved", value: "920K" },
	{ label: "increase in farmers' incomes", value: "37%" },
];
const heroAudienceCards = [
	{
		href: "/sell-with-us",
		buttonLabel: "Sell with us",
		background: HomeSvgs.HeroSvg01,
		description: "The future of food starts with you",
		iconLayers: [{ html: HomeSvgs.HeroSvg02, className: "inset-0" }],
		titleLines: ["For Kenyan", "Farmers"],
	},
	{
		href: "/kenyan-buyers",
		buttonLabel: "Buy from us",
		background: HomeSvgs.HeroSvg03,
		description: "The future of food delivered to you",
		iconLayers: [
			{ html: HomeSvgs.HeroSvg04, className: "inset-0" },
			{
				html: HomeSvgs.HeroSvg05,
				className: "left-9.5 top-8.25 h-19.75 w-20.5",
			},
		],
		titleLines: ["For Kenyan", "Buyers"],
	},
	{
		href: "/global-buys",
		buttonLabel: "Learn more",
		background: HomeSvgs.HeroSvg06,
		description: "The future of food supplied from Kenya",
		iconLayers: [{ html: HomeSvgs.HeroSvg07, className: "inset-0" }],
		titleLines: ["For Global", "Buyers"],
	},
];
const impactIconGroups = [
	{
		base: HomeSvgs.ImpactSvg01,
		layers: [
			{
				html: HomeSvgs.ImpactSvg02,
				className: "left-[21px] top-[33px] h-[48px] w-[84px]",
			},
		],
	},
	{
		base: HomeSvgs.ImpactSvg03,
		layers: [
			{
				html: HomeSvgs.ImpactSvg04,
				className:
					"left-[37.19px] top-[42.53px] h-[52.471px] w-[51.611px]",
			},
			{
				html: HomeSvgs.ImpactSvg05,
				className:
					"left-[50.03px] top-[28.03px] h-[25.289px] w-[26.005px]",
			},
		],
	},
	{
		base: HomeSvgs.ImpactSvg06,
		layers: [],
	},
];
const dateFormatter = new Intl.DateTimeFormat("en-GB", {
	day: "2-digit",
	month: "short",
	year: "numeric",
});
const cmsNewsItems = (await getCollection("news", ({ data }) => data.published))
	.sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
	.slice(0, 3)
	.map(({ body, data, id }) => ({
		date: dateFormatter.format(data.date),
		excerpt: body?.trim() ?? "",
		href: data.link ?? "/news-events",
		image: data.image,
		title: data.title,
		slug: id,
	}));
const cmsImpactMetrics = (await getCollection("impact"))
	.sort((a, b) => a.data.order - b.data.order)
	.slice(0, 3)
	.map(({ body, data, id }) => ({
		description: body?.trim() ?? "",
		label: data.label,
		metric: data.metric,
		slug: id,
		unit: data.unit,
		value: data.value,
	}));
const displayImpactMetrics = fallbackImpactMetrics.map(
	(fallbackMetric, index) => cmsImpactMetrics[index] ?? fallbackMetric,
);
const displayNewsItems = cmsNewsItems.length ? cmsNewsItems : defaultNewsItems;
function isExternalUrl(href?: string) {
	return href ? /^https?:\/\//.test(href) : false;
}
---

<Layout title="Home">
	<div class="bg-[#fbf3e9] relative w-full min-h-screen" data-page="home">
		<section
			class="bg-[#fbf3e9] min-h-screen relative w-full"
			data-section="hero">
			<div
				class="absolute inset-0 pointer-events-none select-none"
				data-name="Hero artwork">
				<OptimizedImage
					alt=""
					aria-hidden="true"
					class="block size-full object-cover object-center"
					fetchpriority="high"
					loading="eager"
					quality={88}
					sizes="100vw"
					src={heroHomeImage}
					widths={[640, 960, 1280, 1600, 1920]}
				/>
			</div>
			<ContentContainer
				size="wide"
				class="relative z-10 grid min-h-screen place-items-center">
				<div
					class="flex flex-col gap-8 items-center max-w-xl text-center w-full mt-0 md:-mt-40">
					<h1
						class={`${typeStyles.heroTitleXL} text-green-500 w-full`}>
						Shaping the Future of Food
					</h1>
					<p class={`${typeStyles.bodyLead} text-orange-500 w-full`}>
						Connecting farmers, markets, and ingredients through
						smarter supply chains.
					</p>
				</div>
			</ContentContainer>
		</section>

		<section
			class="-mt-32 md:-mt-64 lg:-mt-72 relative z-10"
			data-section="audiences">
			<ContentContainer size="wide" class="relative z-10 pb-30">
				<div
					class="grid gap-16 justify-items-center md:grid-cols-3 md:gap-8 lg:gap-16"
					data-layout="audience-grid">
					{
						heroAudienceCards.map((card) => (
							<article class="relative min-h-[420px] w-full max-w-[303px] text-center">
								<div class="pointer-events-none absolute top-20 h-74.5 w-75.75 select-none">
									<div class="absolute inset-[-1.34%_-7.92%_-14.77%_-7.92%]">
										<Fragment set:html={card.background} />
									</div>
								</div>
								<div class="relative z-10 flex min-h-[420px] flex-col items-center px-8 pb-18">
									<div class="relative h-38.5 w-39.5">
										{card.iconLayers.map((layer) => (
											<div
												class={`absolute ${layer.className}`}>
												<Fragment
													set:html={layer.html}
												/>
											</div>
										))}
									</div>
									<div class="flex flex-1 flex-col items-center justify-center gap-4 text-center w-full">
										<h2
											class={`${typeStyles.cardTitle} text-[#0f251b]`}>
											{card.titleLines.map(
												(line, index) => (
													<span class="block leading-normal">
														{line}
													</span>
												),
											)}
										</h2>
										<p
											class={`${typeStyles.body} text-green-500 w-full`}>
											{card.description}
										</p>
									</div>
								</div>
								<Button
									href={card.href}
									size="sm"
									class="absolute bottom-6 left-1/2 z-10 -translate-x-1/2">
									{card.buttonLabel}
								</Button>
							</article>
						))
					}
				</div>
			</ContentContainer>
		</section>
		<section
			class="bg-[#fbf3e9] overflow-clip relative w-full pb-40"
			data-section="intro">
			<ContentContainer size="wide" class="relative z-10">
				<div class="grid justify-items-center gap-16 text-center">
					<div
						class={`${typeStyles.sectionTitle} text-green-700 w-full max-w-5xl`}>
						<h2>
							At Farm to Feed, we believe a better food system
							starts with a better supply chain. One that works
							for farmers, businesses, and the planet alike.
						</h2>
					</div>
					<div
						class={`${typeStyles.body} max-w-xl text-green-500 w-full`}>
						<p class="leading-copy mb-2">
							In Sub-Saharan Africa, nearly half of all fruits and
							vegetables go to waste - driving emissions, hurting
							farmers, and weakening food security. Meanwhile,
							buyers face unreliable supply, high costs, and poor
							traceability.
						</p>
						<p class="leading-copy">
							Since 2021, Farm to Feed, a women-led Kenyan startup
							has been closing this gap. We rescue imperfect and
							surplus produce, extend shelf life and connect
							farmers to fair and reliable markets. Our seamless
							platform allows buyers to source fresh, traceable
							and affordable food with confidence.
						</p>
					</div>
					<Button href="/our-impact" size="lg" class="text-white">
						View Our Impact
					</Button>
				</div>
			</ContentContainer>
			<div
				class="absolute flex inset-[86.19%_-14.03%_-53.63%_-20.21%] items-center justify-center"
				style="container-type: size;">
				<div
					class="-scale-x-100 flex-none h-[100cqw] rotate-90 w-[100cqh]">
					<div class="relative size-full" data-name="Vector">
						<Fragment set:html={HomeSvgs.StorySvg01} />
					</div>
				</div>
			</div>
		</section>

		<section
			class="bg-olive-200 relative w-full lg:h-[300vh]"
			data-supply-chain>
			<ContentContainer
				size="wide"
				class="lg:sticky lg:top-0 lg:grid lg:min-h-screen lg:items-center">
				<div
					class="grid gap-12 lg:grid-cols-[minmax(0,579px)_minmax(0,517px)] lg:gap-20 lg:items-center lg:justify-between"
					data-layout="supply-chain-grid">
					<div
						class="flex flex-col gap-8 md:gap-10 lg:gap-12 w-full lg:w-[579px]"
						data-content="benefit-list">
						{
							supplyChainBenefits.map((benefit, index) => {
								const isActive = index === 0;
								return (
									<article
										class={`lg:border-l-2 lg:pl-8 lg:transition-[border-color,opacity] lg:duration-300 ${isActive ? "lg:border-green-500 lg:opacity-100" : "lg:border-transparent lg:opacity-70"}`}
										data-supply-benefit
										data-supply-index={index}>
										<h3
											class={`${typeStyles.featureTitle} font-medium text-green-800 lg:transition-colors lg:duration-300 ${isActive ? "lg:text-green-800" : "lg:text-green-700"}`}>
											{benefit.title}
										</h3>
										<p
											class={`mt-4 text-green-500 lg:transition-colors lg:duration-300 ${isActive ? "lg:text-green-500" : "lg:text-green-600"}`}>
											{benefit.description}
										</p>
										<OptimizedImage
											alt={benefit.imageAlt}
											class="mt-8 block aspect-[517/552] w-full object-contain sm:mx-auto sm:w-[80%] lg:hidden"
											height="552"
											sizes="(max-width: 640px) 100vw, 80vw"
											src={benefit.image}
											widths={[320, 517, 768]}
											width="517"
										/>
									</article>
								);
							})
						}
					</div>
					<figure
						class="relative hidden aspect-[517/552] w-full max-w-[517px] sm:w-[80%] lg:block lg:w-[517px]"
						data-media="benefit-image">
						{
							supplyChainBenefits.map((benefit, index) => {
								const isActive = index === 0;
								return (
									<OptimizedImage
										alt={isActive ? benefit.imageAlt : ""}
										aria-hidden={
											isActive ? "false" : "true"
										}
										class={`absolute inset-0 block size-full object-contain transition-opacity duration-500 ease-out ${isActive ? "opacity-100" : "opacity-0"}`}
										data-supply-alt={benefit.imageAlt}
										data-supply-image
										data-supply-index={index}
										height="552"
										sizes="517px"
										src={benefit.image}
										widths={[320, 517]}
										width="517"
									/>
								);
							})
						}
						<figcaption class="sr-only" data-supply-caption>
							{supplyChainBenefits[0].imageAlt}
						</figcaption>
					</figure>
				</div>
			</ContentContainer>
		</section>

		<section
			class="bg-white overflow-clip relative w-full pt-64"
			data-section="supply-chain-diagram">
			<BackgroundBottomSvg
				className="absolute inset-x-0 top-0 w-full max-w-none pointer-events-none select-none"
				fill="#DAE2B6"
			/>
			<div
				class="mx-auto grid w-full place-items-center md:w-3/4"
				data-media="supply-chain-diagram">
				<img
					alt=""
					aria-hidden="true"
					class="block h-auto w-full"
					src={supplyChainImage}
				/>
			</div>
			<ContentContainer size="wide" class="relative z-10 py-24">
				<div
					class="grid justify-items-center gap-16 mx-auto max-w-3xl text-center">
					<h2
						class={`${typeStyles.sectionTitle} text-[#0f251b] w-full`}>
						We produce excellence for all actors in the supply
						chain, from farmer to customer
					</h2>
					<Button href="/our-impact" size="lg" data-name="order">
						Learn More
					</Button>
				</div>
			</ContentContainer>
		</section>
		<section
			class="bg-yellow-200 overflow-clip relative w-full"
			data-section="impact-metrics">
			<BackgroundBottomSvg
				className="absolute inset-x-0 top-0 w-full max-w-none pointer-events-none select-none"
				fill="#FFFFFF"
			/>
			<ContentContainer size="wide" class="relative z-10">
				<div
					class={`grid gap-10 sm:grid-cols-2 lg:grid-cols-[minmax(0,368px)_repeat(3,minmax(0,1fr))] ${sectionSpacing.roomy} lg:pt-[325px]`}>
					<h2
						class={`${typeStyles.calloutTitle} text-brown-800 text-center lg:text-left w-full sm:col-span-2 lg:col-span-1`}>
						By keeping food in the human food supply chain, we have
						an impact on various levels:
					</h2>
					{
						displayImpactMetrics.map((metric, index) => {
							const icon = impactIconGroups[index];
							return (
								<article class="flex flex-col gap-8 md:gap-[56px] items-center lg:items-start justify-self-center lg:justify-self-start w-full max-w-[214px]">
									<div
										class="relative h-[122.46px] w-[125.707px]"
										aria-hidden="true">
										<Fragment set:html={icon.base} />
										{icon.layers.map((layer) => (
											<div
												class={`absolute ${layer.className}`}>
												<Fragment
													set:html={layer.html}
												/>
											</div>
										))}
									</div>
									<div class="flex flex-col gap-6 items-center lg:items-start text-center lg:text-left w-full">
										<p
											class={`${typeStyles.statValue} text-[#4c352b] w-full`}>
											{metric.value}
										</p>
										<p
											class={`${typeStyles.body} text-[#7b6a62] w-full`}>
											{metric.label}
										</p>
									</div>
								</article>
							);
						})
					}
				</div>
			</ContentContainer>
			<div
				class="absolute flex inset-[94.81%_0_0_0] items-center justify-center"
				style="container-type: size;">
				<div class="-scale-x-100 flex-none h-[100cqh] w-[100cqw]">
					<div class="relative size-full">
						<Fragment set:html={HomeSvgs.ImpactSvg07} />
					</div>
				</div>
			</div>
		</section>

		<section
			class={`${sectionSpacing.default} bg-[#fbfafa] overflow-clip relative w-full`}
			data-section="news">
			<ContentContainer size="wide">
				<div
					class="grid gap-12 lg:gap-[80px] max-w-[1280px] w-full"
					data-layout="news-grid">
					<div
						class="grid gap-8 sm:grid-cols-[minmax(0,768px)_auto] sm:items-end sm:justify-between w-full">
						<div
							class="flex flex-col gap-4 items-start max-w-[768px] min-w-px">
							<p
								class={`${typeStyles.bodyLarge} leading-7 text-[#b3b3b3]`}>
								News Stories
							</p>
							<h2
								class={`${typeStyles.sectionTitleLarge} text-black w-full`}>
								Check out our latest News!
							</h2>
						</div>
						<Button
							href="/news-events"
							size="sm"
							class="w-fit text-[#eee]">
							View All
						</Button>
					</div>
					<div
						class="grid gap-8 md:grid-cols-2 lg:grid-cols-3 w-full">
						{
							displayNewsItems.map((item) => (
								<article class="flex flex-col items-start min-w-px overflow-clip rounded-4xl">
									<div class="aspect-405/270 relative w-full">
										<OptimizedImage
											alt={item.title}
											class="absolute inset-0 max-w-none object-cover pointer-events-none size-full"
											sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 405px"
											src={item.image}
											widths={[320, 405, 640, 810]}
										/>
									</div>
									<div class="flex flex-col gap-6 items-start py-6 md:py-[32px] w-full">
										<div class="flex flex-col gap-4 items-start w-full">
											<p
												class={`${typeStyles.caption} text-green-500`}>
												{item.date}
											</p>
											<h3
												class={`${typeStyles.cardTitleSmall} text-[#0f251b] md:text-2xl w-full`}>
												{item.title}
											</h3>
										</div>
										<a
											class="flex gap-2 items-center justify-center"
											href={item.href ?? "/news-events"}
											rel={
												isExternalUrl(item.href)
													? "noreferrer"
													: undefined
											}
											target={
												isExternalUrl(item.href)
													? "_blank"
													: undefined
											}>
											<span
												class={`${typeStyles.body} leading-normal text-[#916f96]`}>
												Read more
											</span>
											<span class="overflow-clip relative size-6">
												<span class="absolute inset-[25.72%_36.66%_25.88%_35.46%]">
													<Fragment
														set:html={
															HomeSvgs.NewsSvg01
														}
													/>
												</span>
											</span>
										</a>
									</div>
								</article>
							))
						}
					</div>
				</div>
			</ContentContainer>
			<div class="absolute inset-[95.35%_0_-0.02%_0]">
				<Fragment set:html={HomeSvgs.NewsSvg02} />
			</div>
		</section>
	</div>
	<script>
		const supplyChain = document.querySelector("[data-supply-chain]");
		if (supplyChain) {
			const benefits = Array.from(
				supplyChain.querySelectorAll("[data-supply-benefit]"),
			);
			const images = Array.from(
				supplyChain.querySelectorAll("[data-supply-image]"),
			);
			const caption = supplyChain.querySelector("[data-supply-caption]");
			let frame = null;
			const setActive = (activeIndex) => {
				benefits.forEach((benefit, index) => {
					const isActive = index === activeIndex;
					const title = benefit.querySelector("h3");
					const copy = benefit.querySelector("p");
					benefit.classList.toggle("lg:border-green-500", isActive);
					benefit.classList.toggle("lg:opacity-100", isActive);
					benefit.classList.toggle(
						"lg:border-transparent",
						!isActive,
					);
					benefit.classList.toggle("lg:opacity-70", !isActive);
					title?.classList.toggle("lg:text-green-800", isActive);
					title?.classList.toggle("lg:text-green-700", !isActive);
					copy?.classList.toggle("lg:text-green-500", isActive);
					copy?.classList.toggle("lg:text-green-600", !isActive);
				});
				images.forEach((image, index) => {
					const isActive = index === activeIndex;
					image.classList.toggle("opacity-100", isActive);
					image.classList.toggle("opacity-0", !isActive);
					image.setAttribute(
						"aria-hidden",
						isActive ? "false" : "true",
					);
					image.setAttribute(
						"alt",
						isActive
							? image.getAttribute("data-supply-alt") || ""
							: "",
					);
					if (isActive && caption) {
						caption.textContent =
							image.getAttribute("data-supply-alt") || "";
					}
				});
			};
			const updateActiveBenefit = () => {
				if (window.innerWidth < 1024) {
					setActive(0);
					return;
				}
				const rect = supplyChain.getBoundingClientRect();
				const scrollDistance =
					supplyChain.offsetHeight - window.innerHeight;
				const rawProgress =
					scrollDistance > 0 ? -rect.top / scrollDistance : 0;
				const progress = Math.min(Math.max(rawProgress, 0), 1);
				const nextIndex = Math.min(
					Math.floor(progress * benefits.length),
					benefits.length - 1,
				);
				setActive(nextIndex);
			};
			const requestUpdate = () => {
				if (frame !== null) return;
				frame = window.requestAnimationFrame(() => {
					frame = null;
					updateActiveBenefit();
				});
			};
			updateActiveBenefit();
			window.addEventListener("scroll", requestUpdate, { passive: true });
			window.addEventListener("resize", requestUpdate);
		}
	</script>
</Layout>
