---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
import ContentContainer from "../components/layout/ContentContainer.astro";
import SectionShell from "../components/layout/SectionShell.astro";
import ResponsiveGrid from "../components/layout/ResponsiveGrid.astro";
import * as ImpactSvgs from "../lib/figmaMarkup/impactSvgs";
import BackgroundBottomImpactSvg from "../components/figma/BackgroundBottomImpactSvg.astro";
import { sectionSpacing, typeStyles } from "../lib/figmaStyles";
import impactHeroProduceImage from "../assets/figma/our-impact/hero-produce.png?url";
import empowerFarmersIcon from "../assets/figma/our-impact/empower-farmers-communities.svg?url";
import reliableMarketAccessIcon from "../assets/figma/our-impact/reliable-market-access.svg?url";
import zeroWasteIcon from "../assets/figma/our-impact/zerp-waste.svg?url";
import climateFriendlyIcon from "../assets/figma/our-impact/climate-friendly.svg?url";
import impactIllustrationImage from "../assets/figma/our-impact/impact-illustration.png?url";
import impactBusinessSourcingImage from "../assets/figma/our-impact/impact-illustration-2.png?url";
import sdg01NoPovertyImage from "../assets/figma/our-impact/sdg-01-no-poverty.png?url";
import sdg02ZeroHungerImage from "../assets/figma/our-impact/sdg-02-zero-hunger.png?url";
import sdg08DecentWorkImage from "../assets/figma/our-impact/sdg-08-decent-work.png?url";
import sdg05GenderEqualityImage from "../assets/figma/our-impact/sdg-05-gender-equality.png?url";
import sdg04QualityEducationImage from "../assets/figma/our-impact/sdg-04-quality-education.png?url";
import sdg07CleanEnergyImage from "../assets/figma/our-impact/sdg-07-clean-energy.png?url";
import sdg12ResponsibleConsumptionImage from "../assets/figma/our-impact/sdg-12-responsible-consumption.png?url";
import sdg13ClimateActionImage from "../assets/figma/our-impact/sdg-13-climate-action.png?url";
import sdg15LifeOnLandImage from "../assets/figma/our-impact/sdg-15-life-on-land.png?url";
const indirectSdgIcons = [
	{ label: "Quality education", src: sdg04QualityEducationImage },
	{ label: "Gender equality", src: sdg05GenderEqualityImage },
	{ label: "Affordable and clean energy", src: sdg07CleanEnergyImage },
	{ label: "Decent work and economic growth", src: sdg08DecentWorkImage },
	{ label: "Life on land", src: sdg15LifeOnLandImage },
];
const sdgTargetCards = [
	{
		label: "No poverty",
		src: sdg01NoPovertyImage,
		blobColor: "#E81F2D",
		badgeNumber: "1",
		text: "Through market acces, we generate additional income for smallholder farmers, who make up a large proportion of the rural poor and often live on less than $2 a day.",
	},
	{
		label: "Zero hunger",
		src: sdg02ZeroHungerImage,
		blobColor: "#DDA83A",
		text: "We contribute to food security by increasing the availability of safe and nutritious food through more efficient and sustainable agricultural supply chains.",
	},
	{
		label: "Gender equality",
		src: sdg05GenderEqualityImage,
		blobColor: "#FF3A21",
		text: "We remove barriers to market access, giving women — who form the majority of smallholder farmers — more time to invest in their businesses or education. We have also made gender diversity commitments across our workforce, leadership, governance, and supplier ecosystem.",
	},
	{
		label: "Decent work and economic growth",
		src: sdg08DecentWorkImage,
		blobColor: "#A21942",
		text: "Our growth and diversification strategy creates additional job and growth opportunities for young Kenyans.",
	},
	{
		label: "Responsible consumption and production",
		src: sdg12ResponsibleConsumptionImage,
		blobColor: "#BF8B2E",
		text: "We prevent food loss by creating market demand for the full harvest, including produce that does not meet traditional buyer requirements. By keeping more edible produce in the human food system, we reduce waste and improve resource efficiency across the supply chain.",
	},
	{
		label: "Climate action",
		src: sdg13ClimateActionImage,
		blobColor: "#3F7E44",
		intro: "We avoid greenhouse gas emissions in two ways:",
		items: [
			"Offsetting similar demand: if food is eaten instead of discarded, less food will have to be produced and fewer emissions result.",
			"Avoiding food loss destination emissions: if food is eaten instead of discarded, emissions related to food loss destination (e.g. a landfill) are avoided.",
		],
	},
];
const transformSizeStyle =
	"--transform-inner-width: 1185; --transform-inner-height: 21;";
---

<Layout title="Our Impact">
	<div
		class="bg-white flex flex-col items-center relative w-full min-h-screen overflow-hidden"
		data-name="Impact">
		<div class="bg-olive-200 min-h-[986px] relative w-full">
			<div
				class="absolute flex h-[620.8px] items-center justify-center left-[79.24%] right-[-24.34%] top-[157px]"
				style="container-type: size;">
				<div class="flex-none h-[100cqw] rotate-90 w-[100cqh]">
					<div class="relative size-full">
						<Fragment set:html={ImpactSvgs.ImpactSvg01} />
					</div>
				</div>
			</div>
			<ContentContainer
				size="wide"
				class="pt-[170px] pb-[96px] md:pt-[220px] md:pb-[128px]">
				<div
					class="grid gap-12 lg:grid-cols-[minmax(0,515px)_minmax(0,624px)] lg:items-start lg:justify-between lg:gap-[80px]">
					<div
						class="flex flex-col gap-10 items-start not-italic relative">
						<div class="flex flex-col gap-10 items-start relative">
							<div
								class={`${typeStyles.heroTitleLarge} relative text-[#0f251b] w-full max-w-[519px]`}>
								<p class="leading-tight">
									Building resilient <br aria-hidden="true" /> food
									systems
								</p>
							</div>
							<p
								class={`${typeStyles.bodyLead} relative text-green-500 w-full max-w-[515px]`}>
								Agriculture is the backbone of Kenya's rural
								economy, yet 7.2 million smallholder farmers
								remain economically vulnerable due to fragmented
								markets and unreliable payments.
							</p>
						</div>
						<p
							class={`${typeStyles.body} relative text-green-500 w-full max-w-[515px]`}>
							At the same time, up to 50% of fresh produce in
							Sub-Saharan Africa is lost between harvest and
							market. With Africa's population projected to double
							by 2050 and climate change threatening productivity,
							the urgency to build inclusive food systems has
							never been greater.
						</p>
					</div>
					<div class="flex flex-col gap-16 items-end relative w-full">
						<div
							class="bg-[#eff6ef] relative rounded-[30px] w-full">
							<div
								aria-hidden="true"
								class="absolute border border-[#f7f7f7] border-solid inset-0 pointer-events-none rounded-[30px]">
							</div>
							<div
								class="flex flex-col gap-[27px] items-start px-6 py-8 relative size-full md:px-[32px] md:py-[48px]">
								<div class="flex items-center relative w-full">
									<p
										class={`${typeStyles.cardTitle} not-italic relative text-black w-full`}>
										Why
									</p>
								</div>
								<p
									class={`${typeStyles.body} not-italic relative text-black w-full`}>
									Inefficient supply chains cause significant
									food loss, leading to lost income, avoidable
									emissions, and wasted resources. African
									produce remains under-utilised globally.
								</p>
								<div
									class="absolute contents left-[-32px] top-[-49px]">
									<div
										class="absolute flex h-[80px] items-center justify-center left-[-32px] top-[-49px] w-[82px]">
										<div
											class="-scale-y-100 flex-none rotate-180">
											<div
												class="h-[80px] relative w-[82px]"
												data-name="Vector">
												<Fragment
													set:html={ImpactSvgs.ImpactSvg02}
												/>
											</div>
										</div>
									</div>
									<div
										class="absolute h-[32px] left-[-19px] top-[-25px] w-[56px]">
										<div
											class="absolute h-[32px] left-0 top-0 w-[56px]"
											data-name="Capa_1">
											<Fragment
												set:html={ImpactSvgs.ImpactSvg03}
											/>
										</div>
									</div>
								</div>
							</div>
						</div>
						<div
							class="bg-[#eff6ef] relative rounded-[30px] w-full">
							<div
								aria-hidden="true"
								class="absolute border border-[#f7f7f7] border-solid inset-0 pointer-events-none rounded-[30px]">
							</div>
							<div
								class="flex flex-col gap-[27px] items-start px-6 py-8 relative size-full md:px-[32px] md:py-[48px]">
								<div class="flex items-center relative w-full">
									<p
										class={`${typeStyles.cardTitle} not-italic relative text-black w-full`}>
										How
									</p>
								</div>
								<p
									class={`${typeStyles.body} not-italic relative text-black w-full`}>
									Farm to Feed builds structured, transparent,
									and demand-driven supply chains. Using
									digital tools, farmer training, and value
									addition, we create consistent markets for
									farmers while improving supply chain
									efficiency, extending product shelf life,
									and reducing environmental impact.
								</p>
								<div
									class="absolute h-[80px] left-[-32px] top-[-50.68px] w-[82px]">
									<Fragment
										set:html={ImpactSvgs.ImpactSvg04}
									/>
								</div>
							</div>
						</div>
					</div>
				</div>
			</ContentContainer>
		</div>
		<div
			class="bg-white min-h-0 relative w-full lg:min-h-[1971px]"
			data-name="Wireframe - 11">
			<BackgroundBottomImpactSvg
				className="absolute inset-x-0 top-0 w-full max-w-none pointer-events-none select-none"
				fill="#dae2b6"
			/>
			<div
				class="absolute hidden md:flex inset-[1.61%_31.62%_85.61%_20.85%] items-center justify-center"
				style="container-type: size;">
				<div
					class="flex-none h-[hypot(-97.8483cqw,19.2264cqh)] rotate-[85.86deg] w-[hypot(2.1517cqw,80.7736cqh)]">
					<div class="relative size-full" data-name="Vector">
						<Fragment set:html={ImpactSvgs.ImpactSvg05} />
					</div>
				</div>
			</div>
			<div
				class="absolute hidden md:block inset-[0.33%_22.5%_87.76%_19.93%]">
				<img
					alt=""
					class="block h-full w-full object-contain"
					height="235"
					src={impactHeroProduceImage}
					width="829"
				/>
			</div>
			<ContentContainer
				size="wide"
				class="pt-12 pb-24 md:pt-[220px] md:pb-30 lg:pt-[277px]">
				<div class="flex flex-col gap-8 items-center relative w-full">
					<div
						class="flex flex-col gap-6 items-center max-w-[1052px] not-italic relative text-center w-full md:gap-8 pt-12">
						<p
							class={`${typeStyles.sectionTitle} relative text-[#0f251b] w-full`}>
							Our strategy is built on the conviction that food
							systems only work when farmers, markets, and the
							environment are strengthened together.
						</p>
						<p
							class={`${typeStyles.body} relative text-orange-500 w-full`}>
							We translate this approach into five integrated
							pillars
						</p>
					</div>
					<div
						class="flex flex-col gap-8 items-start relative w-full">
						<div class="grid gap-8 relative w-full lg:grid-cols-2">
							<div
								class="bg-olive-200 content-stretch flex flex-col gap-[27px] items-start p-[32px] md:p-[48px] relative rounded-[30px] w-full lg:flex-[1.42_1_0]">
								<div
									class="content-stretch flex flex-col gap-[24px] items-start justify-center relative shrink-0">
									<img
										alt=""
										class="h-[80px] w-[85px] shrink-0"
										height="80"
										src={empowerFarmersIcon}
										width="85"
									/>
									<p
										class="font-serif font-normal leading-[normal] not-italic relative shrink-0 text-[#0f251b] text-[24px] tracking-[0.72px]">
										Empower Farmers & Communities
									</p>
								</div>
								<p
									class="font-sans font-normal leading-copy not-italic relative shrink-0 text-[16px] text-black tracking-[0.48px] w-full">
									We strengthen farmer capabilities and local
									employment to build resilient livelihoods
									across the supply chain.
								</p>
								<div
									class="grid gap-8 items-start not-italic relative shrink-0 w-full sm:grid-cols-2">
									<div
										class="flex flex-col gap-[14px] items-start relative min-w-0 w-full md:gap-[18px]">
										<p
											class="font-serif font-normal leading-none relative shrink-0 text-[#1e4a35] text-[48px] tracking-[1.44px] w-full">
											235
										</p>
										<p
											class="font-sans font-normal leading-copy relative shrink-0 text-[#0f251b] text-[16px] tracking-[0.48px] w-full">
											Farmers Trained
										</p>
									</div>
									<div
										class="flex flex-col gap-[14px] items-start relative min-w-0 w-full md:gap-[18px]">
										<p
											class="font-serif font-normal leading-none relative shrink-0 text-[#1e4a35] text-[48px] tracking-[1.44px] w-full">
											1094
										</p>
										<p
											class="font-sans font-normal leading-copy relative shrink-0 text-[#0f251b] text-[16px] tracking-[0.48px] w-full">
											Jobs Created
										</p>
									</div>
								</div>
							</div>
							<div
								class="bg-olive-200 content-stretch flex flex-col gap-[27px] items-start p-[32px] md:p-[48px] relative rounded-[30px] w-full lg:flex-1">
								<div
									class="content-stretch flex flex-col gap-[24px] items-start justify-center relative shrink-0">
									<img
										alt=""
										class="h-[80px] w-[79px] shrink-0"
										height="80"
										src={reliableMarketAccessIcon}
										width="79"
									/>
									<p
										class="font-serif font-normal leading-[normal] not-italic relative shrink-0 text-[#0f251b] text-[24px] tracking-[0.72px]">
										Provide Reliable Market Access
									</p>
								</div>
								<p
									class="font-sans font-normal leading-copy not-italic relative shrink-0 text-[16px] text-black tracking-[0.48px] w-full">
									We provide reliable market access that
									reduces risk and stabilises farmer income.
								</p>
								<div
									class="grid gap-8 items-start not-italic relative shrink-0 w-full sm:grid-cols-2">
									<div
										class="flex flex-col gap-[14px] items-start relative min-w-0 w-full md:gap-[18px]">
										<p
											class="font-serif font-normal leading-none relative shrink-0 text-[#1e4a35] text-[48px] tracking-[1.44px] w-full">
											+294%
										</p>
										<p
											class="font-sans font-normal leading-copy relative shrink-0 text-[#0f251b] text-[16px] tracking-[0.48px] w-full">
											Farmer Income Increase
										</p>
									</div>
									<div
										class="flex flex-col gap-[14px] items-start relative min-w-0 w-full md:gap-[18px]">
										<p
											class="font-serif font-normal leading-none relative shrink-0 text-[#1e4a35] text-[48px] tracking-[1.44px] w-full">
											$100
										</p>
										<p
											class="font-sans font-normal leading-copy relative shrink-0 text-[#0f251b] text-[16px] tracking-[0.48px] w-full">
											Total Income to Farmers
										</p>
									</div>
								</div>
							</div>
						</div>
						<div class="grid gap-8 relative w-full lg:grid-cols-2">
							<div
								class="bg-olive-200 content-stretch flex flex-col gap-[27px] items-start p-[32px] md:p-[48px] relative rounded-[30px] w-full lg:flex-[1.42_1_0]">
								<div
									class="content-stretch flex flex-col gap-[24px] items-start justify-center relative shrink-0">
									<img
										alt=""
										class="h-[80px] w-[75px] shrink-0"
										height="80"
										src={zeroWasteIcon}
										width="75"
									/>
									<p
										class="font-serif font-normal leading-[normal] not-italic relative shrink-0 text-[#0f251b] text-[24px] tracking-[0.72px]">
										Build Zero-Waste Supply Chains
									</p>
								</div>
								<p
									class="font-sans font-normal leading-copy not-italic relative shrink-0 text-[16px] text-black tracking-[0.48px] w-full">
									We reduce food loss by keeping more of the
									harvest in the human food supply chain.
								</p>
								<div
									class="grid gap-8 items-start not-italic relative shrink-0 w-full sm:grid-cols-3">
									<div
										class="flex flex-col gap-[14px] items-start relative min-w-0 w-full md:gap-[18px]">
										<p
											class="font-serif font-normal leading-none relative shrink-0 text-[#1e4a35] text-[48px] tracking-[1.44px] w-full">
											1M
										</p>
										<p
											class="font-sans font-normal leading-copy relative shrink-0 text-[#0f251b] text-[16px] tracking-[0.48px] w-full">
											KGs Rescued
										</p>
									</div>
									<div
										class="flex flex-col gap-[14px] items-start relative min-w-0 w-full md:gap-[18px]">
										<p
											class="font-serif font-normal leading-none relative shrink-0 text-[#1e4a35] text-[48px] tracking-[1.44px] w-full">
											2,410
										</p>
										<p
											class="font-sans font-normal leading-copy relative shrink-0 text-[#0f251b] text-[16px] tracking-[0.48px] w-full">
											tonnes CO2e avoided
										</p>
									</div>
									<div
										class="flex flex-col gap-[14px] items-start relative min-w-0 w-full md:gap-[18px]">
										<p
											class="font-serif font-normal leading-none relative shrink-0 text-[#1e4a35] text-[48px] tracking-[1.44px] w-full">
											66M
										</p>
										<p
											class="font-sans font-normal leading-copy relative shrink-0 text-[#0f251b] text-[16px] tracking-[0.48px] w-full">
											blue water wastage avoided
										</p>
									</div>
								</div>
							</div>
							<div
								class="bg-olive-200 content-stretch flex flex-col gap-[27px] items-start p-[32px] md:p-[48px] relative rounded-[30px] w-full lg:flex-1">
								<div
									class="content-stretch flex flex-col gap-[24px] items-start justify-center relative shrink-0">
									<img
										alt=""
										class="h-[80px] w-[97px] shrink-0"
										height="80"
										src={climateFriendlyIcon}
										width="97"
									/>
									<p
										class="font-serif font-normal leading-[normal] not-italic relative shrink-0 text-[#0f251b] text-[24px] tracking-[0.72px]">
										Create Climate-Friendly Products
									</p>
								</div>
								<p
									class="font-sans font-normal leading-copy not-italic relative shrink-0 text-[16px] text-black tracking-[0.48px] w-full">
									We strengthen climate resilience by
									developing value-added pathways for
									underutilised crops.
								</p>
								<div
									class="grid gap-8 items-start not-italic relative shrink-0 w-full sm:grid-cols-2">
									<div
										class="flex flex-col gap-[14px] items-start relative min-w-0 w-full md:gap-[18px]">
										<p
											class="font-serif font-normal leading-none relative shrink-0 text-[#1e4a35] text-[48px] tracking-[1.44px] w-full">
											6 Month
										</p>
										<p
											class="font-sans font-normal leading-copy relative shrink-0 text-[#0f251b] text-[16px] tracking-[0.48px] w-full">
											Shelf life extension on average
										</p>
									</div>
								</div>
							</div>
						</div>
						<div class="grid grid-cols-1 gap-8 relative w-full">
							<div
								class="bg-olive-200 content-stretch flex flex-col gap-[32px] min-h-[380px] items-start justify-start overflow-hidden p-[32px] md:p-[48px] relative rounded-[30px] w-full lg:flex-row lg:items-center lg:min-h-[422px]">
								<div
									aria-hidden="true"
									class="absolute hidden h-[283.283px] items-center justify-center left-[50%] top-[108px] w-[594.766px] lg:flex">
									<div class="flex-none rotate-[91.75deg]">
										<div
											class="h-[586.926px] relative w-[265.468px]">
											<svg
												class="absolute block inset-0 size-full"
												fill="none"
												preserveAspectRatio="none"
												viewBox="0 0 265.468 586.926"
												xmlns="http://www.w3.org/2000/svg">
												<path
													d="M55.4976 586.907C44.1879 587.473 34.4919 575.607 33.3106 559.741C21.1591 396.533 13.3968 221.815 0.702403 60.0188C-0.330119 46.8322 -1.06108 32.082 4.8427 21.7489C10.68 11.5383 20.9133 9.32606 30.1599 7.84888C63.8324 2.46832 158.339 2.19312 230.047 0.00616154C240.413 -0.310173 248.866 11.5952 248.679 26.2085C246.441 200.666 252.011 375.318 265.359 548.78C266.485 563.412 258.718 576.401 248.297 577.268L55.4976 586.907Z"
													fill="#8C98EE"></path>
											</svg>
										</div>
									</div>
								</div>
								<div
									class="content-stretch flex flex-col gap-[27px] items-start relative shrink-0 w-full lg:max-w-[405px]">
									<div
										class="content-stretch flex flex-col gap-[24px] items-start justify-center relative shrink-0">
										<p
											class="font-serif font-normal leading-[normal] not-italic relative shrink-0 text-[24px] text-black tracking-[0.72px]">
											Unlock Demand and Global Reach
										</p>
									</div>
									<p
										class="font-sans font-normal leading-copy not-italic relative shrink-0 text-[16px] text-black tracking-[0.48px] w-full">
										We unlock regional and global demand for
										locally produced ingredients.
									</p>
								</div>
								<div
									class="flex items-center justify-center relative shrink-0 w-full max-w-[681px] lg:max-w-[681px]">
									<img
										alt=""
										class="block h-auto w-full max-w-[681px]"
										height="351"
										src={impactIllustrationImage}
										width="681"
									/>
								</div>
							</div>
						</div>
					</div>
				</div>
