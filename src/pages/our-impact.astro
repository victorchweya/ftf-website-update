		</div>
		<div class="relative w-full">
			<div
				class="bg-brown-800 min-h-[651px] rounded-tl-4xl rounded-tr-4xl w-full">
				<ContentContainer size="wide" class={sectionSpacing.default}>
					<div
						class="grid gap-12 lg:grid-cols-[568px_minmax(0,1fr)] lg:items-center">
						<div
