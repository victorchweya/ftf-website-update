<script>
	const testimonialSections = document.querySelectorAll(
		"[data-local-buyer-testimonials]",
	);
	testimonialSections.forEach((section) => {
		const testimonials = JSON.parse(
			section.getAttribute("data-testimonials") || "[]",
		);
		const quote = section.querySelector("[data-testimonial-quote]");
		const name = section.querySelector("[data-testimonial-name]");
		const company = section.querySelector("[data-testimonial-company]");
		const previous = section.querySelector("[data-testimonial-previous]");
		const next = section.querySelector("[data-testimonial-next]");
		let index = 0;
		let timer;
		function render(nextIndex) {
			if (!testimonials.length) return;
			index = (nextIndex + testimonials.length) % testimonials.length;
			const active = testimonials[index];
			if (quote) quote.textContent = active.quote;
			if (name) name.textContent = active.name;
			if (company) company.textContent = active.company;
		}
		function restartAutoplay() {
			window.clearInterval(timer);
			timer = window.setInterval(() => render(index + 1), 3000);
		}
		previous?.addEventListener("click", () => {
			render(index - 1);
			restartAutoplay();
		});
		next?.addEventListener("click", () => {
			render(index + 1);
			restartAutoplay();
		});
		render(index);
		restartAutoplay();
	});
</script>
